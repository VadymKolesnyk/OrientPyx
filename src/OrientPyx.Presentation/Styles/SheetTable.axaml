<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:OrientPyx.Presentation.Controls">

    <!-- ============================================================
         Skin + template for the shared editable sheet table (controls:SheetTable).
         A true two-tier banded header the DataGrid cannot do. The body is a
         virtualized ListBox; the header is built in code into PART_HeaderSlot.
         Wrap in Border.card for the rounded frame, like the sheet grids.
         ============================================================ -->

    <!-- The multi-column sort editor's flyout: lift the FlyoutPresenter's default MaxWidth (288) and drop
         its padding so the fixed-width, aligned editor panel is neither clipped nor forced to scroll
         horizontally. Matched via SheetSortButton's FlyoutPresenterClasses="sortFlyout". -->
    <Style Selector="FlyoutPresenter.sortFlyout">
        <Setter Property="MaxWidth" Value="900" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="controls|SheetTable">
        <Setter Property="Template">
            <ControlTemplate>
                <!-- The body ListBox owns BOTH scrollbars (vertical + horizontal) so they stay
                     pinned to the visible viewport edges. The header sits in its own clip viewport
                     and its horizontal offset is slaved to the body's scroller in code, so the two
                     scroll left/right in lockstep while the header stays frozen vertically. -->
                <DockPanel LastChildFill="True" MinWidth="200"
                           Background="{DynamicResource SurfaceCard}">
                    <!-- Built-in toolbar: active-filter chips on the left, then a global "search all
                         columns" box and the column show/hide gear on the right. Lives inside the table
                         so every page gets it with no per-view markup. The chips bar collapses to nothing
                         when no filter is active. The search box filters rows by a "contains" match over
                         every visible column; Ctrl+F anywhere in the table focuses it. -->
                    <DockPanel DockPanel.Dock="Top" LastChildFill="True" Margin="8,6"
                               Background="Transparent">
                        <controls:SheetColumnsButton DockPanel.Dock="Right"
                            Table="{Binding $parent[controls:SheetTable]}"
                            Localization="{Binding Localization, RelativeSource={RelativeSource TemplatedParent}}" />
                        <!-- Custom multi-column sort editor, next to the search box. -->
                        <controls:SheetSortButton DockPanel.Dock="Right" Margin="0,0,6,0"
                            Table="{Binding $parent[controls:SheetTable]}"
                            Localization="{Binding Localization, RelativeSource={RelativeSource TemplatedParent}}" />
                        <Grid DockPanel.Dock="Right" Width="170" Margin="0,0,6,0"
                              VerticalAlignment="Center">
                            <TextBox Name="PART_Search" Height="26" MinHeight="0"
                                     VerticalContentAlignment="Center"
                                     PlaceholderText="{Binding Localization[Sheet.Search.Watermark], RelativeSource={RelativeSource TemplatedParent}}"
                                     ToolTip.Tip="{Binding Localization[Sheet.Search.Tooltip], RelativeSource={RelativeSource TemplatedParent}}"
                                     Padding="23,0,20,0" />
                            <!-- Search (magnifier) glyph on the left. PathIcon FILLS its geometry, so the
                                 ring is drawn as an even-odd donut (outer circle minus inner circle) and the
                                 handle as a filled stroke — an outline path would render as a solid blob. -->
                            <PathIcon Width="11" Height="11"
                                      HorizontalAlignment="Left" Margin="7,0,0,0"
                                      IsHitTestVisible="False"
                                      Foreground="{DynamicResource TextSecondary}">
                                <PathIcon.Data>
                                    <PathGeometry FillRule="EvenOdd"
                                        Figures="M7,1 A6,6 0 1 1 6.99,1 Z M7,3 A4,4 0 1 0 7.01,3 Z M11.2,11.9 L10,13.1 L13.8,16.9 L15,15.7 Z" />
                                </PathIcon.Data>
                            </PathIcon>
                            <!-- Clear (✕) button, shown only when there is text. -->
                            <Button Name="PART_SearchClear"
                                    Classes="ghost"
                                    IsVisible="False"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Width="16" Height="16" MinWidth="0" MinHeight="0"
                                    Padding="0" Margin="0,0,2,0" CornerRadius="4">
                                <!-- Two crossed strokes (a Path with Stroke, not a filled PathIcon). -->
                                <Path Data="M0,0 L7,7 M7,0 L0,7" Width="7" Height="7"
                                      Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Button>
                        </Grid>
                        <controls:SheetFilterBar
                            Table="{Binding $parent[controls:SheetTable]}"
                            Localization="{Binding Localization, RelativeSource={RelativeSource TemplatedParent}}" />
                    </DockPanel>

                    <!-- Frozen, code-built banded header. Its own ScrollViewer clips horizontally;
                         scrollbars are hidden — the body drives the offset. -->
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource SurfaceHeader}"
                            BorderBrush="{DynamicResource BorderSubtle}"
                            BorderThickness="0,0,0,1"
                            ClipToBounds="True">
                        <ScrollViewer Name="PART_HeaderScroll"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Disabled">
                            <Decorator Name="PART_HeaderSlot" />
                        </ScrollViewer>
                    </Border>

                    <!-- Status bar (opt-in): per-column sums aligned under their columns (scrolls with
                         the body) above a fixed line with row counts + page-supplied system info. The
                         whole bar collapses when there is nothing to show. Docked to the bottom, below
                         the rows, so it stays pinned while the body scrolls internally. -->
                    <Border Name="PART_StatusBar"
                            DockPanel.Dock="Bottom"
                            IsVisible="False"
                            Background="{DynamicResource SurfaceHeader}"
                            BorderBrush="{DynamicResource BorderSubtle}"
                            BorderThickness="0,1,0,0">
                        <StackPanel Orientation="Vertical">
                            <!-- Aligned per-column sums; clipped + horizontally slaved to the body. -->
                            <Border Name="PART_StatusSumsRow"
                                    ClipToBounds="True"
                                    IsVisible="False"
                                    MinHeight="26">
                                <ScrollViewer Name="PART_StatusScroll"
                                              HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Disabled">
                                    <Decorator Name="PART_StatusSlot" />
                                </ScrollViewer>
                            </Border>
                            <!-- Fixed info line: counts (large) on the left, system info on the right. -->
                            <Grid ColumnDefinitions="Auto,*,Auto" Margin="10,5">
                                <TextBlock Name="PART_StatusCounts" Grid.Column="0"
                                           VerticalAlignment="Center"
                                           FontSize="15" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}" />
                                <TextBlock Name="PART_StatusInfo" Grid.Column="2"
                                           VerticalAlignment="Center"
                                           TextAlignment="Right"
                                           Foreground="{DynamicResource TextSecondary}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Virtualized rows. Fills the remaining height; rows align to the top so they
                         sit directly under the header (no centered gap). Owns both scrollbars; the
                         horizontal one drives the header.
                         NOTE: the VirtualizingStackPanel must stretch to fill the ListBox viewport.
                         Giving it VerticalAlignment="Top" sizes it to the content of only the rows
                         realized on the first pass, so the panel never grows to the viewport and the
                         remaining rows are never materialized — the table then shows a subset and
                         shuffles which rows appear when the source is sorted/refiltered. The ListBox
                         already lays its rows out top-down, so stretching the panel keeps them under
                         the header without dropping rows. -->
                    <ListBox Name="PART_Body"
                             Background="Transparent"
                             BorderThickness="0"
                             SelectionMode="Single"
                             VerticalAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                    </ListBox>
                </DockPanel>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- Header sub-cells: dense, header-toned, like the sheet grid headers -->
    <Style Selector="controls|SheetTable Border > TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
        <Setter Property="FontWeight" Value="Medium" />
    </Style>

    <!-- Header band/sub-cell separators: stronger, more visible vertical rules -->
    <Style Selector="controls|SheetTable Grid#PART_HeaderSlot Border">
        <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
        <Setter Property="MinHeight" Value="38" />
    </Style>

    <!-- Sort icon button on the right of each header cell -->
    <Style Selector="controls|SheetTable Button.rosterSort">
        <Setter Property="Width" Value="26" />
        <Setter Property="Height" Value="26" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="controls|SheetTable Button.rosterSort:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BorderSubtle}" />
    </Style>

    <!-- Resize grips in the header: a wide transparent hit zone with a centered grip line that
         strengthens to the accent colour on hover so the draggable edge is discoverable. -->
    <Style Selector="controls|SheetTable Thumb.rosterResize">
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="Transparent">
                    <!-- Right-aligned so the visible line sits exactly on the column's right edge,
                         lining up with the body cell border (not floating left of it). -->
                    <Rectangle Name="grip"
                               Width="2"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Stretch"
                               Margin="0,6"
                               Fill="{DynamicResource BorderStrong}" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="controls|SheetTable Thumb.rosterResize:pointerover /template/ Rectangle#grip">
        <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Width" Value="2.5" />
    </Style>

    <!-- Rows: compact, gridlined like the sheet -->
    <Style Selector="controls|SheetTable ListBoxItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <!-- Cell hosts: vertical gridlines + the focused-cell accent outline (Excel cue).
         Custom template so a selection wash can be painted ABOVE any custom cell Background
         (payment/age/row-highlight tints). A ContentControl's default template paints Background
         then Content, leaving no layer for a selection overlay; here PART_SelectionOverlay sits
         between the (tinted) background border and the content, so a selected row stays visible
         even under tinted columns. -->
    <Style Selector="controls|SheetTable controls|SheetCell">
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="FontSize" Value="13" />
        <!-- Transparent (not null) so the whole cell area is hit-testable; :range overrides it. -->
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                    <Panel>
                        <!-- Translucent selection/range wash, toggled by the :selected / :range
                             pseudo-classes below. Transparent by default so it's invisible. -->
                        <Border Name="PART_SelectionOverlay" Background="Transparent" />
                        <ContentPresenter Name="PART_ContentPresenter"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Padding="{TemplateBinding Padding}" />
                    </Panel>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <!-- Selected row: wash every cell (including tinted ones) so the selection reads across all columns. -->
    <Style Selector="controls|SheetTable controls|SheetCell:selected /template/ Border#PART_SelectionOverlay">
        <Setter Property="Background" Value="{DynamicResource AccentSurface}" />
    </Style>
    <!-- Cells inside an Excel-style multi-cell selection: a translucent accent wash painted on the
         overlay (above any custom cell tint), so range selection reads under tinted columns too. The
         anchor cell keeps the :focus outline below (border vs. overlay, so they stack rather than conflict). -->
    <Style Selector="controls|SheetTable controls|SheetCell:range /template/ Border#PART_SelectionOverlay">
        <Setter Property="Background" Value="{DynamicResource AccentSurface}" />
    </Style>
    <Style Selector="controls|SheetTable controls|SheetCell:focus">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="1.5" />
    </Style>

    <!-- In-cell editors: borderless, fill the cell, no rounded corners  -->
    <Style Selector="controls|SheetTable controls|SheetCell TextBox">
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="controls|SheetTable controls|SheetCell ComboBox">
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <!-- The ComboBox's content presenter must stretch too, or the control paints its selected text in
         a short intrinsic-height box centred in the cell rather than filling the row's height. -->
    <Style Selector="controls|SheetTable controls|SheetCell ComboBox /template/ ContentControl#ContentPresenter">
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <!-- A date cell edits 1:1 like a text cell (flat, borderless input, no height jump). The picker's
         templated parts (inner PART_TextBox, its PART_BorderElement, and the PART_Button glyph) each
         carry the app-wide MinHeight=38, which grows the row. Those parts live two template levels deep
         and a "SheetCell CalendarDatePicker /template/ …" selector does NOT reach them, so the flattening
         is done in code in LazyDateCell.OnPickerTemplateApplied. This picker-level style only handles the
         outer chrome (borders/background) that the selector can reach. -->
    <Style Selector="controls|SheetTable controls|SheetCell CalendarDatePicker">
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

</Styles>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:OrientPyx.Presentation.ViewModels"
             xmlns:controls="using:OrientPyx.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="640"
             x:Class="OrientPyx.Presentation.Views.EventSelectionView"
             x:DataType="vm:EventSelectionViewModel">

    <Border Background="{DynamicResource SurfacePage}" Padding="40">
        <Grid RowDefinitions="Auto,*,Auto" Width="860" HorizontalAlignment="Center">

            <!-- Brand + title -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,8,0,20">
                <StackPanel Grid.Column="0" Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Image Source="/Assets/orientpyx.png" Width="40" Height="40" />
                        <TextBlock Text="{Binding Localization[EventSelection.Title]}" Classes="h1"
                                   VerticalAlignment="Center"
                                   FontSize="{ReflectionBinding TitleFontSize, Source={StaticResource UiScale}}" />
                    </StackPanel>
                    <TextBlock Text="{Binding Localization[EventSelection.Subtitle]}" Classes="subtitle" />
                </StackPanel>

                <!-- Reveal hidden competitions. Only shown when at least one is hidden. -->
                <ToggleSwitch Grid.Column="1" VerticalAlignment="Bottom"
                              IsVisible="{Binding HasHidden}"
                              IsChecked="{Binding ShowHidden, Mode=TwoWay}"
                              OnContent="{Binding Localization[EventSelection.ShowHidden]}"
                              OffContent="{Binding Localization[EventSelection.ShowHidden]}" />
            </Grid>

            <!-- Spreadsheet-style table; the card border supplies the rounded frame. Columns are built
                 in code-behind (SheetColumnBuilder) and handed to the shared SheetTable via Bands. -->
            <Border Grid.Row="1" Classes="card" ClipToBounds="True">
                <Panel>
                    <controls:SheetTable Name="Sheet"
                                         ItemsSource="{Binding Events}"
                                         Localization="{Binding Localization}"
                                         SelectedItem="{Binding SelectedEvent, Mode=TwoWay}"
                                         DoubleTapped="OnRowDoubleTapped" />

                    <!-- Empty state, shown over the (empty) table -->
                    <StackPanel IsVisible="{Binding !Events.Count}"
                                Spacing="10" Margin="0,48" HorizontalAlignment="Center" VerticalAlignment="Center"
                                IsHitTestVisible="False">
                        <Border Width="56" Height="56" CornerRadius="28"
                                Background="{DynamicResource AccentSurface}" HorizontalAlignment="Center">
                            <controls:Icon Kind="FolderOpen"
                                      Size="26" Foreground="{DynamicResource AccentBrush}" />
                        </Border>
                        <TextBlock Text="{Binding Localization[EventSelection.Empty]}" Classes="muted"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Panel>
            </Border>

            <!-- Actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10" Margin="0,20,0,0">
                <Button Content="{Binding Localization[EventSelection.Open]}"
                        Command="{Binding OpenCommand}"
                        Classes="accent" />
                <Button Content="{Binding Localization[EventSelection.Create]}"
                        Command="{Binding CreateCommand}"
                        Classes="ghost" />
            </StackPanel>

        </Grid>
    </Border>

</UserControl>

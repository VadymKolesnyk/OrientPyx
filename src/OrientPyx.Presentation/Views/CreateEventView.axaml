<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:OrientPyx.Presentation.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="640"
             x:Class="OrientPyx.Presentation.Views.CreateEventView"
             x:DataType="vm:CreateEventViewModel">

    <Border Background="{DynamicResource SurfacePage}" Padding="40">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      HorizontalAlignment="Center" VerticalAlignment="Center">
        <Border Classes="card" Padding="32" Width="480"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Spacing="16">

                <StackPanel Spacing="4" Margin="0,0,0,4">
                    <TextBlock Text="{Binding Localization[CreateEvent.Title]}" Classes="h1"
                               FontSize="{ReflectionBinding TitleFontSize, Source={StaticResource UiScale}}" />
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Localization[CreateEvent.Name]}" Classes="label" />
                    <TextBox Text="{Binding Name, Mode=TwoWay}"
                             PlaceholderText="{Binding Localization[CreateEvent.Name.Hint]}" />
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Localization[CreateEvent.Identifier]}" Classes="label" />
                    <TextBox Text="{Binding Identifier, Mode=TwoWay}"
                             PlaceholderText="{Binding Localization[CreateEvent.Identifier.Hint]}" />
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Localization[CreateEvent.Venue]}" Classes="label" />
                    <TextBox Text="{Binding Venue, Mode=TwoWay}"
                             PlaceholderText="{Binding Localization[CreateEvent.Venue.Hint]}" />
                </StackPanel>

                <!-- Day count on its own row. A custom +/- stepper, not NumericUpDown, whose
                     Windows automation peer crashes on spin ("UnsupportedType Decimal"). -->
                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Localization[CreateEvent.DayCount]}" Classes="label" />
                    <Border BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1"
                            CornerRadius="6" Padding="2" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="2">
                            <Button Content="−" Command="{Binding DecrementDaysCommand}"
                                    Classes="ghost stepper" />
                            <TextBlock Text="{Binding DayCount}" MinWidth="44"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       TextAlignment="Center" FontWeight="Medium" />
                            <Button Content="+" Command="{Binding IncrementDaysCommand}"
                                    Classes="ghost stepper" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Single day: one full-width "Date" field (saved as both start and end). -->
                <StackPanel Spacing="6" IsVisible="{Binding !IsMultiDay}">
                    <TextBlock Text="{Binding Localization[CreateEvent.Date]}" Classes="label" />
                    <CalendarDatePicker SelectedDate="{Binding StartDate, Mode=TwoWay,
                                            Converter={StaticResource DateTimeOffsetToDateTime}}"
                                        SelectedDateFormat="Custom"
                                        CustomDateFormatString="dd.MM.yyyy"
                                        PlaceholderText="{Binding Localization[Common.DatePlaceholder]}"
                                        HorizontalAlignment="Stretch" />
                </StackPanel>

                <!-- Multi-day: editable start and end dates side by side, filling the width. -->
                <Grid ColumnDefinitions="*,20,*" IsVisible="{Binding IsMultiDay}">
                    <StackPanel Grid.Column="0" Spacing="6">
                        <TextBlock Text="{Binding Localization[CreateEvent.StartDate]}" Classes="label" />
                        <CalendarDatePicker SelectedDate="{Binding StartDate, Mode=TwoWay,
                                                Converter={StaticResource DateTimeOffsetToDateTime}}"
                                            SelectedDateFormat="Custom"
                                            CustomDateFormatString="dd.MM.yyyy"
                                            PlaceholderText="{Binding Localization[Common.DatePlaceholder]}"
                                            HorizontalAlignment="Stretch" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="6">
                        <TextBlock Text="{Binding Localization[CreateEvent.EndDate]}" Classes="label" />
                        <CalendarDatePicker SelectedDate="{Binding EndDate, Mode=TwoWay,
                                                Converter={StaticResource DateTimeOffsetToDateTime}}"
                                            SelectedDateFormat="Custom"
                                            CustomDateFormatString="dd.MM.yyyy"
                                            PlaceholderText="{Binding Localization[Common.DatePlaceholder]}"
                                            HorizontalAlignment="Stretch" />
                    </StackPanel>
                </Grid>

                <!-- Officials (optional) — collapsed by default to keep the form compact. Editable later
                     on the Information page too. Each named official has an optional judge category. -->
                <Expander Header="{Binding Localization[CompetitionInfo.Officials]}" Padding="0">
                    <StackPanel Spacing="12" Margin="0,12,0,0">
                        <Grid ColumnDefinitions="*,12,130">
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="{Binding Localization[CompetitionInfo.CourseSetter]}" Classes="label" />
                                <TextBox Text="{Binding CourseSetter, Mode=TwoWay}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="6">
                                <TextBlock Text="{Binding Localization[CompetitionInfo.JudgeCategory]}" Classes="label" />
                                <TextBox Text="{Binding CourseSetterCategory, Mode=TwoWay}" />
                            </StackPanel>
                        </Grid>
                        <Grid ColumnDefinitions="*,12,130">
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="{Binding Localization[CompetitionInfo.ChiefJudge]}" Classes="label" />
                                <TextBox Text="{Binding ChiefJudge, Mode=TwoWay}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="6">
                                <TextBlock Text="{Binding Localization[CompetitionInfo.JudgeCategory]}" Classes="label" />
                                <TextBox Text="{Binding ChiefJudgeCategory, Mode=TwoWay}" />
                            </StackPanel>
                        </Grid>
                        <Grid ColumnDefinitions="*,12,130">
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="{Binding Localization[CompetitionInfo.ChiefSecretary]}" Classes="label" />
                                <TextBox Text="{Binding ChiefSecretary, Mode=TwoWay}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="6">
                                <TextBlock Text="{Binding Localization[CompetitionInfo.JudgeCategory]}" Classes="label" />
                                <TextBox Text="{Binding ChiefSecretaryCategory, Mode=TwoWay}" />
                            </StackPanel>
                        </Grid>
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding Localization[CompetitionInfo.Jury]}" Classes="label" />
                            <TextBox Text="{Binding Jury, Mode=TwoWay}" AcceptsReturn="True"
                                     TextWrapping="Wrap" MinHeight="64" />
                        </StackPanel>
                    </StackPanel>
                </Expander>

                <!-- Inline error -->
                <Border IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        Background="{DynamicResource DangerSurface}" CornerRadius="8" Padding="12,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="M12,2 a10,10 0 1 0 0,20 a10,10 0 0 0 0,-20 z M12,7 v6 M12,16 v0.5"
                                  Width="16" Height="16" Foreground="{DynamicResource DangerBrush}"
                                  VerticalAlignment="Top" Margin="0,2,0,0" />
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,8,0,0">
                    <Button Content="{Binding Localization[CreateEvent.Submit]}"
                            Command="{Binding CreateCommand}"
                            IsEnabled="{Binding !IsBusy}"
                            Classes="accent" />
                    <Button Content="{Binding Localization[CreateEvent.Cancel]}"
                            Command="{Binding CancelCommand}"
                            Classes="ghost" />
                </StackPanel>

            </StackPanel>
        </Border>
        </ScrollViewer>
    </Border>

</UserControl>

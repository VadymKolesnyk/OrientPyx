<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dialogs="using:OrientPyx.Presentation.ViewModels.Dialogs"
             mc:Ignorable="d" d:DesignWidth="460" d:DesignHeight="300"
             x:Class="OrientPyx.Presentation.Views.Dialogs.ImportEventView"
             x:DataType="dialogs:ImportEventViewModel">

    <!-- Centered card; the backdrop is supplied by the host overlay. -->
    <Border Background="{DynamicResource SurfaceCard}"
            CornerRadius="12"
            MinWidth="420" MaxWidth="520"
            BoxShadow="0 10 40 0 #40000000"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            ClipToBounds="True">
        <DockPanel LastChildFill="True">

            <!-- Header -->
            <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceCard}"
                    BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,0,0,1"
                    Padding="22,16">
                <TextBlock Text="{Binding Title}" Classes="h2" VerticalAlignment="Center" />
            </Border>

            <!-- Footer actions -->
            <Border DockPanel.Dock="Bottom" Background="{DynamicResource SurfaceCard}"
                    BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,1,0,0"
                    Padding="22,14">
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                    <Button Content="{Binding Localization[Common.Cancel]}"
                            Classes="ghost"
                            Command="{Binding CancelCommand}" />
                    <!-- Conflict case: overwrite the existing competition -->
                    <Button Content="{Binding Localization[ImportEvent.Overwrite]}"
                            Classes="ghost danger"
                            IsVisible="{Binding IdentifierExists}"
                            Command="{Binding OverwriteCommand}" />
                    <!-- Conflict case: "import under new name". -->
                    <Button Classes="accent"
                            Content="{Binding Localization[ImportEvent.ImportAsNew]}"
                            IsVisible="{Binding IdentifierExists}"
                            Command="{Binding ConfirmCommand}" />
                    <!-- Free case: single OK. -->
                    <Button Classes="accent"
                            Content="{Binding Localization[Common.Ok]}"
                            IsVisible="{Binding IdentifierFree}"
                            Command="{Binding ConfirmCommand}" />
                </StackPanel>
            </Border>

            <!-- Body -->
            <StackPanel Margin="22,18" Spacing="14">
                <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextPrimary}" />

                <!-- New-identifier field, only shown on a conflict -->
                <StackPanel Spacing="6" IsVisible="{Binding IdentifierExists}">
                    <TextBlock Text="{Binding Localization[ImportEvent.NewName]}" Classes="label" />
                    <TextBox Text="{Binding NewIdentifier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="—" />
                    <TextBlock Text="{Binding NewIdentifierError}"
                               IsVisible="{Binding NewIdentifierError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               Foreground="{DynamicResource DangerBrush}"
                               FontSize="12" TextWrapping="Wrap" />
                </StackPanel>
            </StackPanel>

        </DockPanel>
    </Border>

</UserControl>

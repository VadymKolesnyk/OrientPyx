<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dialogs="using:OrientPyx.Presentation.ViewModels.Dialogs"
             mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="240"
             x:Class="OrientPyx.Presentation.Views.Dialogs.ImportOptionsView"
             x:DataType="dialogs:ImportOptionsViewModel">

    <!-- Centered card; the backdrop is supplied by the host overlay. -->
    <Border Background="{DynamicResource SurfaceCard}"
            CornerRadius="12"
            MinWidth="380" MaxWidth="460"
            BoxShadow="0 10 40 0 #40000000"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            ClipToBounds="True">
        <DockPanel LastChildFill="True">

            <!-- Header -->
            <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceCard}"
                    BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,0,0,1"
                    Padding="22,16">
                <TextBlock Text="{Binding Title}" Classes="h2" VerticalAlignment="Center" />
            </Border>

            <!-- Footer actions -->
            <Border DockPanel.Dock="Bottom" Background="{DynamicResource SurfaceCard}"
                    BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,1,0,0"
                    Padding="22,14">
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                    <Button Content="{Binding Localization[Common.Cancel]}"
                            Classes="ghost"
                            Command="{Binding CancelCommand}" />
                    <Button Content="{Binding Localization[Common.Ok]}"
                            Classes="accent"
                            Command="{Binding ConfirmCommand}" />
                </StackPanel>
            </Border>

            <!-- Body: message + optional scope chooser + toggles -->
            <StackPanel Margin="22,18" Spacing="14">
                <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Classes="muted" />

                <!-- Day scope (participant imports only): all days per file vs current day + link field. -->
                <StackPanel Spacing="8" IsVisible="{Binding HasScope}">
                    <RadioButton GroupName="ImportScope"
                                 Content="{Binding Scope.AllDaysLabel}"
                                 IsChecked="{Binding !Scope.CurrentDayOnly, Mode=TwoWay}" />
                    <RadioButton GroupName="ImportScope"
                                 Content="{Binding Scope.CurrentDayLabel}"
                                 IsChecked="{Binding Scope.CurrentDayOnly, Mode=TwoWay}" />
                    <StackPanel Margin="26,0,0,0" Spacing="8"
                                IsEnabled="{Binding Scope.CurrentDayOnly}"
                                IsVisible="{Binding Scope.CurrentDayOnly}">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding Scope.LinkPrompt}" Classes="muted" />
                            <ComboBox ItemsSource="{Binding Scope.LinkFields}"
                                      SelectedItem="{Binding Scope.SelectedLinkField, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="dialogs:LinkFieldOption">
                                        <TextBlock Text="{Binding Label}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <!-- Which global participant columns to overwrite on already-existing athletes. -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding Scope.UpdatePrompt}" Classes="muted" TextWrapping="Wrap" />
                            <ItemsControl ItemsSource="{Binding Scope.UpdateFields}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="dialogs:UpdateFieldOption">
                                        <CheckBox Content="{Binding Label}"
                                                  IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                  Margin="0,0,14,0" MinWidth="120" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <ItemsControl ItemsSource="{Binding Options}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="dialogs:ImportOption">
                            <CheckBox Content="{Binding Label}"
                                      IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                      Margin="0,2" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

        </DockPanel>
    </Border>

</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dialogs="using:OrientPyx.Presentation.ViewModels.Dialogs"
             xmlns:pages="using:OrientPyx.Presentation.ViewModels.Pages"
             xmlns:controls="using:OrientPyx.Presentation.Controls"
             xmlns:behaviors="using:OrientPyx.Presentation.Behaviors"
             mc:Ignorable="d" d:DesignWidth="480" d:DesignHeight="560"
             x:Class="OrientPyx.Presentation.Views.Dialogs.FinishReadoutEditView"
             x:DataType="dialogs:FinishReadoutEditViewModel">

    <!-- Centered card; the backdrop is supplied by the host overlay. -->
    <Border Background="{DynamicResource SurfaceCard}"
            CornerRadius="12"
            MinWidth="460" MaxWidth="520" MaxHeight="640"
            BoxShadow="0 10 40 0 #40000000"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            ClipToBounds="True">
        <DockPanel LastChildFill="True">

            <!-- Header -->
            <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceCard}"
                    BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,0,0,1"
                    Padding="22,16">
                <TextBlock Text="{Binding Title}" Classes="h2" VerticalAlignment="Center" />
            </Border>

            <!-- Footer actions -->
            <Border DockPanel.Dock="Bottom" Background="{DynamicResource SurfaceCard}"
                    BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,1,0,0"
                    Padding="22,14">
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                    <Button Content="{Binding Localization[Common.Cancel]}"
                            Classes="ghost"
                            Command="{Binding CancelCommand}" />
                    <Button Content="{Binding Localization[Common.Save]}"
                            Classes="accent"
                            Command="{Binding ConfirmCommand}" />
                </StackPanel>
            </Border>

            <!-- Body: scrollable so the punch list never pushes the footer off-screen. -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="22,18" Spacing="14">

                    <!-- Chip number, read-only, shown as a plain line above the editable fields -->
                    <TextBlock Text="{Binding ChipLine}" FontWeight="Medium" />

                    <!-- Reassign chip holder -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding HolderLabel}" Classes="label" />
                        <controls:SearchableComboBox ItemsSource="{Binding Participants}"
                                  SelectedItem="{Binding SelectedParticipant, Mode=TwoWay}"
                                  SearchWatermark="{Binding Localization[Common.Search]}"
                                  HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="dialogs:ReassignOption">
                                    <TextBlock Text="{Binding Label}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </controls:SearchableComboBox>
                    </StackPanel>


                    <!-- Start + finish times on one row -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Text="{Binding StartLabel}" Classes="label" />
                            <TextBox Text="{Binding StartTimeText, Mode=TwoWay}"
                                     behaviors:NumericInput.Time="True" PlaceholderText="—" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="6">
                            <TextBlock Text="{Binding FinishLabel}" Classes="label" />
                            <TextBox Text="{Binding FinishTimeText, Mode=TwoWay}"
                                     behaviors:NumericInput.Time="True" PlaceholderText="—" />
                        </StackPanel>
                    </Grid>

                    <!-- Status override -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding StatusLabel}" Classes="label" />
                        <ComboBox ItemsSource="{Binding Statuses}"
                                  SelectedItem="{Binding SelectedStatus, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="pages:FinishStatusOption">
                                    <TextBlock Text="{Binding Label}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <!-- Punches: code + time per row, add/remove -->
                    <StackPanel Spacing="6">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="{Binding PunchesLabel}" Classes="label"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1" Classes="ghost small"
                                    Command="{Binding AddPunchCommand}"
                                    Content="{Binding Localization[FinishRead.Edit.AddPunch]}" />
                        </Grid>

                        <ItemsControl ItemsSource="{Binding Punches}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="dialogs:PunchEditViewModel">
                                    <Grid ColumnDefinitions="*,120,Auto" ColumnSpacing="8" Margin="0,3">
                                        <TextBox Grid.Column="0" Text="{Binding Code, Mode=TwoWay}"
                                                 PlaceholderText="{Binding $parent[ItemsControl].((dialogs:FinishReadoutEditViewModel)DataContext).Localization[FinishRead.Splits.Col.Code]}" />
                                        <TextBox Grid.Column="1" Text="{Binding TimeText, Mode=TwoWay}"
                                                 behaviors:NumericInput.Time="True" PlaceholderText="—" />
                                        <Button Grid.Column="2" Classes="ghost small danger"
                                                VerticalAlignment="Center"
                                                Command="{Binding $parent[ItemsControl].((dialogs:FinishReadoutEditViewModel)DataContext).RemovePunchCommand}"
                                                CommandParameter="{Binding}"
                                                Content="✕" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <TextBlock Text="{Binding TimeHint}" Classes="subtitle" TextWrapping="Wrap" />

                </StackPanel>
            </ScrollViewer>

        </DockPanel>
    </Border>

</UserControl>

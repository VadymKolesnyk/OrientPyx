<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dialogs="using:OrientPyx.Presentation.ViewModels.Dialogs"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="720"
             x:Class="OrientPyx.Presentation.Views.Dialogs.StatementView"
             x:DataType="dialogs:StatementViewModel">

    <!-- A wide modal card hosting the live statement preview + the configuration controls + actions. -->
    <Border Classes="card" Padding="0" MaxWidth="960" MaxHeight="820"
            HorizontalAlignment="Center" VerticalAlignment="Center">
        <DockPanel LastChildFill="True">

            <!-- Title bar -->
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="22,20,22,10">
                <TextBlock Grid.Column="0" Text="{Binding Title}" Classes="h2" VerticalAlignment="Center" />
                <CheckBox Grid.Column="1" IsChecked="{Binding IsLandscape, Mode=TwoWay}"
                          Content="{Binding LandscapeLabel}" VerticalAlignment="Center" />
            </Grid>

            <!-- Actions row (bottom) -->
            <Grid DockPanel.Dock="Bottom" ColumnDefinitions="Auto,*,Auto" Margin="22,10,22,20">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="{Binding SaveForNextLabel}" Classes="ghost"
                            Command="{Binding SaveSettingsCommand}" />
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                                IsVisible="{Binding SettingsSaved}">
                        <TextBlock Text="✓" Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding SettingsSavedHint}"
                                   Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="{Binding PrintSettingsLabel}" Classes="ghost"
                            Command="{Binding EditPrintSettingsCommand}" />
                    <Button Content="{Binding PrintLabel}"
                            Command="{Binding PrintCommand}" />
                    <Button Content="{Binding ExportWordLabel}" Classes="accent"
                            Click="OnExportWordClick" />
                    <Button Content="{Binding CloseLabel}" Classes="ghost"
                            Command="{Binding CloseCommand}" />
                </StackPanel>
            </Grid>

            <!-- Body: the page preview + column checkboxes -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                          MaxHeight="640">
                <StackPanel Spacing="14" Margin="22,0,22,6">

                    <!-- The document mock-up: a fixed-size page-shaped sheet in true A4 proportions -->
                    <Border Background="#EEF0F4" CornerRadius="6" Padding="24">
                        <Border Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                CornerRadius="2" Padding="26" ClipToBounds="True"
                                HorizontalAlignment="Center" VerticalAlignment="Top"
                                BoxShadow="0 2 10 0 #22000000"
                                Width="{Binding Preview.IsLandscape, Converter={StaticResource LandscapeToPageSize}, ConverterParameter=width}"
                                Height="{Binding Preview.IsLandscape, Converter={StaticResource LandscapeToPageSize}, ConverterParameter=height}">
                            <StackPanel Spacing="4">
                                <!-- The statement has NO header block (no competition name / title / date /
                                     venue) — just the applied-filters heading (centred, bold) over the table. -->
                                <TextBlock Text="{Binding Preview.FilterSummary}" FontWeight="Bold"
                                           FontSize="12" Foreground="Black" TextAlignment="Center"
                                           Margin="0,2,0,0" TextWrapping="Wrap"
                                           IsVisible="{Binding Preview.HasFilterSummary}" />

                                <!-- Empty hint when there are no rows -->
                                <TextBlock Text="{Binding EmptyHint}" Foreground="#888"
                                           FontStyle="Italic" FontSize="11" Margin="0,10,0,0" TextWrapping="Wrap"
                                           IsVisible="{Binding Preview.IsEmpty}" />

                                <!-- The flat table built in code-behind (print-faithful, header drag-reorder). -->
                                <Grid x:Name="PreviewTableHost" Margin="0,8,0,0"
                                      IsVisible="{Binding !Preview.IsEmpty}" />
                            </StackPanel>
                        </Border>
                    </Border>

                    <!-- Column visibility — checkboxes (reorder by dragging the preview headers) -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding ColumnsLabel}" Classes="subtitle" />
                        <ItemsControl ItemsSource="{Binding Columns}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="dialogs:StatementColumnItemViewModel">
                                    <CheckBox VerticalAlignment="Center" Margin="0,0,18,6"
                                              IsChecked="{Binding Visible, Mode=TwoWay}"
                                              Content="{Binding Caption}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

        </DockPanel>
    </Border>

</UserControl>

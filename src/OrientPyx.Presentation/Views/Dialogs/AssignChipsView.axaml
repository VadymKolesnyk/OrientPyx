<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dialogs="using:OrientPyx.Presentation.ViewModels.Dialogs"
             xmlns:behaviors="using:OrientPyx.Presentation.Behaviors"
             mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="360"
             x:Class="OrientPyx.Presentation.Views.Dialogs.AssignChipsView"
             x:DataType="dialogs:AssignChipsViewModel">

    <!-- Centered card; the backdrop is supplied by the host overlay. -->
    <Border Background="{DynamicResource SurfaceCard}"
            CornerRadius="12"
            MinWidth="380" MaxWidth="460"
            BoxShadow="0 10 40 0 #40000000"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            ClipToBounds="True">
        <DockPanel LastChildFill="True">

            <!-- Header -->
            <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceCard}"
                    BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,0,0,1"
                    Padding="22,16">
                <TextBlock Text="{Binding Title}" Classes="h2" VerticalAlignment="Center" />
            </Border>

            <!-- Footer actions -->
            <Border DockPanel.Dock="Bottom" Background="{DynamicResource SurfaceCard}"
                    BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,1,0,0"
                    Padding="22,14">
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                    <Button Content="{Binding Localization[Common.Cancel]}"
                            Classes="ghost"
                            Command="{Binding CancelCommand}" />
                    <Button Content="{Binding Localization[Participants.AssignChips.Confirm]}"
                            Classes="accent"
                            Command="{Binding ConfirmCommand}" />
                </StackPanel>
            </Border>

            <!-- Body -->
            <StackPanel Margin="22,18" Spacing="14">

                <!-- Source mode: draw from the existing rental base, or add-and-assign a new range. -->
                <StackPanel Spacing="8">
                    <TextBlock Text="{Binding Localization[Participants.AssignChips.Source]}" Classes="label" />
                    <RadioButton GroupName="ChipSource"
                                 Content="{Binding Localization[Participants.AssignChips.Source.FromBase]}"
                                 IsChecked="{Binding FromBase, Mode=TwoWay}" />
                    <RadioButton GroupName="ChipSource"
                                 Content="{Binding Localization[Participants.AssignChips.Source.Range]}"
                                 IsChecked="{Binding IsRangeMode, Mode=TwoWay}" />
                </StackPanel>

                <!-- "From the rental base" body: the note filter dropdown. -->
                <StackPanel Spacing="6" IsVisible="{Binding FromBase}">
                    <TextBlock Text="{Binding Localization[Participants.AssignChips.NoteFilter]}" Classes="label" />
                    <ComboBox ItemsSource="{Binding Notes}"
                              SelectedItem="{Binding SelectedNote, Mode=TwoWay}"
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="dialogs:ChipNoteOption">
                                <TextBlock Text="{Binding Label}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Text="{Binding Localization[Participants.AssignChips.Hint]}"
                               Classes="subtitle" TextWrapping="Wrap" />
                </StackPanel>

                <!-- "Starting from a number" body: start number + count + optional note. The range is
                     added to the rental base and then assigned in one step. -->
                <StackPanel Spacing="14" IsVisible="{Binding IsRangeMode}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding Localization[Chips.BulkAdd.Start]}" Classes="label" />
                        <TextBox Text="{Binding StartNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 behaviors:NumericInput.Digits="True"
                                 PlaceholderText="9007400" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding Localization[Chips.BulkAdd.Count]}" Classes="label" />
                        <TextBox Text="{Binding Count, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 behaviors:NumericInput.Digits="True"
                                 PlaceholderText="100" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding Localization[Chips.BulkAdd.Note]}" Classes="label" />
                        <TextBox Text="{Binding RangeNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="—" />
                    </StackPanel>

                    <TextBlock Text="{Binding Localization[Participants.AssignChips.RangeHint]}"
                               Classes="subtitle" TextWrapping="Wrap" />
                </StackPanel>

            </StackPanel>

        </DockPanel>
    </Border>

</UserControl>

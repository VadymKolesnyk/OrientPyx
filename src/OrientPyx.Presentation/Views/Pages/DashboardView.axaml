<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="using:OrientPyx.Presentation.ViewModels.Pages"
             xmlns:controls="using:OrientPyx.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="640"
             x:Class="OrientPyx.Presentation.Views.Pages.DashboardView"
             x:DataType="pages:DashboardViewModel">

    <DockPanel LastChildFill="True">

        <!-- Page heading + refresh -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,20">
            <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                <TextBlock Text="{Binding Title}" Classes="h1"
                           FontSize="{ReflectionBinding TitleFontSize, Source={StaticResource UiScale}}" />
                <TextBlock Text="{Binding Text}" Classes="subtitle" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Button Classes="help" Command="{Binding ShowHelpCommand}"
                        ToolTip.Tip="{Binding Localization[Help.Tooltip]}" />
                <controls:SearchableComboBox IsVisible="{Binding ShowDaySelector}"
                          MinWidth="140" VerticalAlignment="Center"
                          SearchWatermark="{Binding Localization[Common.Search]}"
                          ItemsSource="{Binding DayOptions}"
                          SelectedItem="{Binding SelectedDay, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="pages:DayOption">
                            <TextBlock Text="{Binding Label}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </controls:SearchableComboBox>
                <Button Classes="ghost" VerticalAlignment="Center"
                        Command="{Binding RefreshCommand}"
                        IsVisible="{Binding Info.HasSelection}"
                        Content="{Binding Localization[Dashboard.Refresh]}" />
            </StackPanel>
        </Grid>

        <!-- Empty state: no competition selected -->
        <Border Classes="card" Padding="40" IsVisible="{Binding !Info.HasSelection}">
            <StackPanel Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420">
                <Border Width="72" Height="72" CornerRadius="36"
                        Background="{DynamicResource AccentSurface}" HorizontalAlignment="Center">
                    <controls:Icon Data="{Binding IconData}" Size="34"
                              Foreground="{DynamicResource AccentBrush}" />
                </Border>
                <TextBlock Text="{Binding Localization[Dashboard.Empty.Title]}" Classes="h2"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{Binding Localization[Dashboard.Empty.Text]}" Classes="subtitle"
                           HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- Live dashboard.
             Layout note: every card on this page is a fixed-width (232px) tile laid out in one
             ItemsControl-less set of WrapPanels. Fixed width + VerticalAlignment=Stretch inside each
             row keeps the cards on a single grid rhythm — same width, and equal height per row — so the
             page reflows cleanly at any window width without ragged, mismatched-height columns. -->
        <ScrollViewer IsVisible="{Binding Info.HasSelection}"
                      HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20">

                <!-- Quick actions: kept at the top — the most-used shortcuts while running a competition -->
                <Border Classes="card" Padding="20">
                    <StackPanel Spacing="14">
                        <TextBlock Text="{Binding Localization[Dashboard.Section.QuickActions]}" Classes="label" />
                        <WrapPanel Orientation="Horizontal">
                            <Button Classes="accent" Margin="0,0,10,10"
                                    Command="{Binding QuickActionCommand}"
                                    CommandParameter="{x:Static pages:DashboardQuickAction.Participants}"
                                    Content="{Binding Localization[Dashboard.Action.Participants]}" />
                            <Button Classes="accent" Margin="0,0,10,10"
                                    Command="{Binding QuickActionCommand}"
                                    CommandParameter="{x:Static pages:DashboardQuickAction.FinishRead}"
                                    Content="{Binding Localization[Dashboard.Action.FinishRead]}" />
                            <Button Classes="ghost" Margin="0,0,10,10"
                                    Command="{Binding QuickActionCommand}"
                                    CommandParameter="{x:Static pages:DashboardQuickAction.Draw}"
                                    Content="{Binding Localization[Dashboard.Action.Draw]}" />
                            <Button Classes="ghost" Margin="0,0,10,10"
                                    Command="{Binding QuickActionCommand}"
                                    CommandParameter="{x:Static pages:DashboardQuickAction.StartProtocol}"
                                    Content="{Binding Localization[Dashboard.Action.StartProtocol]}" />
                            <Button Classes="ghost" Margin="0,0,10,10"
                                    Command="{Binding QuickActionCommand}"
                                    CommandParameter="{x:Static pages:DashboardQuickAction.Protocols}"
                                    Content="{Binding Localization[Dashboard.Action.Protocols]}" />
                            <Button Classes="ghost" Margin="0,0,10,10"
                                    Command="{Binding QuickActionCommand}"
                                    CommandParameter="{x:Static pages:DashboardQuickAction.Splits}"
                                    Content="{Binding Localization[Dashboard.Action.Splits]}" />
                            <Button Classes="ghost" Margin="0,0,10,10"
                                    Command="{Binding QuickActionCommand}"
                                    CommandParameter="{x:Static pages:DashboardQuickAction.MonitorResults}"
                                    Content="{Binding Localization[Dashboard.Action.MonitorResults]}" />
                            <Button Classes="ghost" Margin="0,0,10,10"
                                    Command="{Binding QuickActionCommand}"
                                    CommandParameter="{x:Static pages:DashboardQuickAction.OnlineResults}"
                                    Content="{Binding Localization[Dashboard.Action.OnlineResults]}" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Info cards: competition overview, current day, start window, finished breakdown.
                     Same fixed 232px tile width as the stat tiles below (Finished spans two columns);
                     WrapPanel reflows them and the shared 176px Height keeps every card in a row equal
                     height, so nothing sits taller than its neighbour. -->
                <WrapPanel Orientation="Horizontal">

                    <!-- Competition overview -->
                    <Border Classes="card" Width="232" Margin="0,0,14,14" Padding="18" Height="176">
                        <StackPanel Spacing="12">
                            <TextBlock Text="{Binding Localization[Dashboard.Section.Overview]}" Classes="label" />
                            <TextBlock Text="{Binding Info.CompetitionName}" Classes="h2" FontSize="16"
                                       TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxLines="2" />
                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="5" ColumnSpacing="12">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Localization[Dashboard.Overview.Venue]}" Classes="subtitle" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Info.Venue}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding Localization[Dashboard.Overview.Dates]}" Classes="subtitle" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Info.DateRange}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding Localization[Dashboard.Overview.Days]}" Classes="subtitle" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Info.DayCount}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Current day -->
                    <Border Classes="card" Width="232" Margin="0,0,14,14" Padding="18" Height="176">
                        <StackPanel Spacing="12">
                            <TextBlock Text="{Binding Localization[Dashboard.Section.Today]}" Classes="label" />
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Border Classes="badge"><TextBlock Text="{Binding DayLabel}" /></Border>
                                <TextBlock Text="{Binding Info.CurrentDayDate}" Classes="subtitle" VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding Localization[Dashboard.Today.Discipline]}" Classes="subtitle" />
                                <TextBlock Text="{Binding DisciplineName}" FontWeight="Medium" TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Start window → Жеребкування -->
                    <Button Classes="tile" Width="232" Margin="0,0,14,14" Padding="18" Height="176"
                            VerticalContentAlignment="Top"
                            Command="{Binding QuickActionCommand}"
                            CommandParameter="{x:Static pages:DashboardQuickAction.Draw}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="{Binding Localization[Dashboard.Section.Start]}" Classes="label" />
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding Localization[Dashboard.Start.First]}" Classes="subtitle" FontSize="12" />
                                    <TextBlock Text="{Binding FirstStartText}" Classes="h2" FontSize="18"
                                               Foreground="{DynamicResource AccentBrush}" />
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding Localization[Dashboard.Start.Last]}" Classes="subtitle" FontSize="12" />
                                    <TextBlock Text="{Binding LastStartText}" FontSize="18" FontWeight="Medium" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding Localization[Dashboard.Start.Assigned]}" Classes="muted" FontSize="12" />
                                <TextBlock Text="{Binding Info.StartsAssigned}" FontSize="12" FontWeight="SemiBold" />
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <!-- Finished: big total + per-status breakdown badges → Зчитка на фініші.
                         Spans two tile columns so the status badges have room to sit in one tidy row. -->
                    <Button Classes="tile" Margin="0,0,14,14" Padding="18" Height="176" Width="478"
                            VerticalContentAlignment="Top"
                            Command="{Binding QuickActionCommand}"
                            CommandParameter="{x:Static pages:DashboardQuickAction.FinishRead}">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Localization[Dashboard.Stat.Finished]}" Classes="label"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Info.FinishedTotal}" Classes="h1" FontSize="30"
                                           Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center" />
                            </StackPanel>
                            <!-- Uniform status badges: same fixed size, one per occurring status (OK/MP/OVT…). -->
                            <ItemsControl ItemsSource="{Binding FinishedBadges}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="pages:DashboardStatusBadge">
                                        <Border Width="60" Height="48" Margin="0,0,8,8" CornerRadius="6"
                                                Background="{DynamicResource SurfaceSubtle}"
                                                BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1">
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="1">
                                                <TextBlock Text="{Binding Count}" FontSize="18" FontWeight="Bold"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock Text="{Binding Code}" FontSize="11" HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource SuccessBrush}"
                                                           IsVisible="{Binding IsOk}" />
                                                <TextBlock Text="{Binding Code}" FontSize="11" HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource DangerBrush}"
                                                           IsVisible="{Binding !IsOk}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Button>
                </WrapPanel>

                <!-- Stat tiles: same 232px rhythm, uniform 120px height so every tile in a row lines up. -->
                <WrapPanel Orientation="Horizontal">

                    <!-- Participants → Учасники -->
                    <Button Classes="tile" Width="232" Height="120" Margin="0,0,14,14"
                            Command="{Binding QuickActionCommand}"
                            CommandParameter="{x:Static pages:DashboardQuickAction.Participants}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding Localization[Dashboard.Stat.ParticipantsToday]}" Classes="subtitle" />
                            <TextBlock Text="{Binding Info.ParticipantsToday}" Classes="h1" FontSize="30" />
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding Localization[Dashboard.Stat.Participants]}" Classes="muted" FontSize="12" />
                                <TextBlock Text="{Binding Info.ParticipantTotal}" FontSize="12" FontWeight="SemiBold" />
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <!-- Groups today → Групи -->
                    <Button Classes="tile" Width="232" Height="120" Margin="0,0,14,14"
                            Command="{Binding QuickActionCommand}"
                            CommandParameter="{x:Static pages:DashboardQuickAction.Groups}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding Localization[Dashboard.Stat.GroupsToday]}" Classes="subtitle" />
                            <TextBlock Text="{Binding Info.GroupsToday}" Classes="h1" FontSize="30" />
                        </StackPanel>
                    </Button>

                    <!-- Without chip → Учасники (filtered to chipless) -->
                    <Button Classes="tile" Width="232" Height="120" Margin="0,0,14,14"
                            Command="{Binding QuickActionCommand}"
                            CommandParameter="{x:Static pages:DashboardQuickAction.ParticipantsWithoutChip}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding Localization[Dashboard.Stat.WithoutChip]}" Classes="subtitle" />
                            <TextBlock Text="{Binding Info.WithoutChip}" Classes="h1" FontSize="30"
                                       Foreground="{DynamicResource DangerBrush}" />
                        </StackPanel>
                    </Button>

                    <!-- Without group → Учасники (filtered to groupless) -->
                    <Button Classes="tile" Width="232" Height="120" Margin="0,0,14,14"
                            Command="{Binding QuickActionCommand}"
                            CommandParameter="{x:Static pages:DashboardQuickAction.ParticipantsWithoutGroup}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding Localization[Dashboard.Stat.WithoutGroup]}" Classes="subtitle" />
                            <TextBlock Text="{Binding Info.WithoutGroup}" Classes="h1" FontSize="30" />
                        </StackPanel>
                    </Button>

                    <!-- Chips → Чіпи -->
                    <Button Classes="tile" Width="232" Height="120" Margin="0,0,14,14"
                            Command="{Binding QuickActionCommand}"
                            CommandParameter="{x:Static pages:DashboardQuickAction.Chips}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding Localization[Dashboard.Stat.ChipsTotal]}" Classes="subtitle" />
                            <TextBlock Text="{Binding Info.ChipsTotal}" Classes="h1" FontSize="30" />
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="{Binding Localization[Dashboard.Stat.ChipsHandedOut]}" Classes="muted" FontSize="12" />
                                    <TextBlock Text="{Binding Info.ChipsHandedOut}" FontSize="12" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="{Binding Localization[Dashboard.Stat.ChipsFree]}" Classes="muted" FontSize="12" />
                                    <TextBlock Text="{Binding Info.ChipsFree}" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SuccessBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <!-- Read-outs → Зчитка на фініші -->
                    <Button Classes="tile" Width="232" Height="120" Margin="0,0,14,14"
                            Command="{Binding QuickActionCommand}"
                            CommandParameter="{x:Static pages:DashboardQuickAction.FinishRead}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding Localization[Dashboard.Stat.Readouts]}" Classes="subtitle" />
                            <TextBlock Text="{Binding Info.ReadoutsToday}" Classes="h1" FontSize="30" />
                        </StackPanel>
                    </Button>

                    <!-- On course → Учасники (filtered to still-running: no start/finish/status).
                         MinHeight (not a fixed Height like its siblings) so the two optional caption
                         lines — last drawn start + elapsed — can grow the tile when both are shown. -->
                    <Button Classes="tile" Width="232" MinHeight="120" Margin="0,0,14,14"
                            Command="{Binding QuickActionCommand}"
                            CommandParameter="{x:Static pages:DashboardQuickAction.ParticipantsOnCourse}">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding Localization[Dashboard.Stat.OnCourse]}" Classes="subtitle" />
                            <TextBlock Text="{Binding Info.OnCourse}" Classes="h1" FontSize="30"
                                       Foreground="{DynamicResource AccentBrush}" />
                            <TextBlock Text="{Binding OnCourseLastStartLabel}" Classes="muted" FontSize="12"
                                       TextWrapping="Wrap"
                                       IsVisible="{Binding HasOnCourseLastStart}" />
                            <TextBlock Text="{Binding OnCourseElapsedLabel}" Classes="muted" FontSize="12"
                                       TextWrapping="Wrap"
                                       IsVisible="{Binding HasOnCourseElapsed}" />
                        </StackPanel>
                    </Button>
                </WrapPanel>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>

</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="using:OrientPyx.Presentation.ViewModels.Pages"
             xmlns:controls="using:OrientPyx.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="680"
             x:Class="OrientPyx.Presentation.Views.Pages.SummaryProtocolsView"
             x:DataType="pages:SummaryProtocolsViewModel">

    <DockPanel LastChildFill="True">

        <!-- Heading + generate button -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="{Binding Localization[Page.SummaryProtocol.Title]}" Classes="h1"
                           FontSize="{ReflectionBinding TitleFontSize, Source={StaticResource UiScale}}" />
                <TextBlock Text="{Binding Text}" Classes="subtitle" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Classes="help" Command="{Binding ShowHelpCommand}"
                        ToolTip.Tip="{Binding Localization[Help.Tooltip]}" />
                <Button Classes="accent"
                        Click="OnGenerateClick"
                        Content="{Binding Localization[SummaryProtocol.Generate]}" />
            </StackPanel>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="16" MaxWidth="1280">

                <!-- Залік settings -->
                <Border Classes="card" Padding="22">
                    <StackPanel Spacing="14">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Localization[SummaryProtocol.Settings.Title]}" Classes="h2"
                                       VerticalAlignment="Center"
                                       FontSize="{ReflectionBinding SectionFontSize, Source={StaticResource UiScale}}" />
                            <Button Classes="help"
                                    Command="{Binding ShowBlockHelpCommand}" CommandParameter="Help.SummaryProtocol.Settings"
                                    ToolTip.Tip="{Binding Localization[Help.Tooltip]}" />
                        </StackPanel>

                        <!-- Mode -->
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Localization[SummaryProtocol.Mode.Label]}" VerticalAlignment="Center" />
                            <ComboBox MinWidth="220" ItemsSource="{Binding ModeOptions}"
                                      SelectedItem="{Binding SelectedMode, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="pages:SummaryModeOption">
                                        <TextBlock Text="{Binding Caption}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <!-- Require all days (points mode only) -->
                        <CheckBox IsChecked="{Binding RequireAllDays, Mode=TwoWay}"
                                  IsVisible="{Binding IsByPoints}"
                                  Content="{Binding Localization[SummaryProtocol.RequireAllDays]}" />

                        <!-- Days to count + order -->
                        <TextBlock Text="{Binding Localization[SummaryProtocol.Days.Title]}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Localization[SummaryProtocol.Days.Hint]}" Classes="subtitle"
                                   TextWrapping="Wrap" />
                        <ItemsControl ItemsSource="{Binding Days}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="pages:SummaryDayItemViewModel">
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                                        <CheckBox VerticalAlignment="Center" MinWidth="120"
                                                  IsChecked="{Binding Counted, Mode=TwoWay}"
                                                  Content="{Binding Label}" />
                                        <Button Classes="ghost" Padding="6,2"
                                                Content="↑"
                                                Command="{Binding $parent[ItemsControl].((pages:SummaryProtocolsViewModel)DataContext).MoveDayUpCommand}"
                                                CommandParameter="{Binding}" />
                                        <Button Classes="ghost" Padding="6,2"
                                                Content="↓"
                                                Command="{Binding $parent[ItemsControl].((pages:SummaryProtocolsViewModel)DataContext).MoveDayDownCommand}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Priority day -->
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center"
                                    IsVisible="{Binding HasMultipleDays}">
                            <TextBlock Text="{Binding Localization[SummaryProtocol.PriorityDay]}" VerticalAlignment="Center" />
                            <ComboBox MinWidth="160" ItemsSource="{Binding PriorityDayOptions}"
                                      SelectedItem="{Binding PriorityDay, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="pages:DayOption">
                                        <TextBlock Text="{Binding Label}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <!-- Orientation -->
                        <CheckBox IsChecked="{Binding IsLandscape, Mode=TwoWay}"
                                  Content="{Binding Localization[Protocols.Layout.Landscape]}" />
                    </StackPanel>
                </Border>

                <!-- Live document preview (edit the header in place, drag leading column headers to reorder) -->
                <Border Classes="card" Padding="22">
                    <StackPanel Spacing="14">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Localization[Protocols.Preview.Title]}" Classes="h2"
                                       VerticalAlignment="Center"
                                       FontSize="{ReflectionBinding SectionFontSize, Source={StaticResource UiScale}}" />
                            <Button Classes="help"
                                    Command="{Binding ShowBlockHelpCommand}" CommandParameter="Help.SummaryProtocol.Preview"
                                    ToolTip.Tip="{Binding Localization[Help.Tooltip]}" />
                        </StackPanel>
                        <TextBlock Text="{Binding Localization[SummaryProtocol.Preview.Hint]}" Classes="subtitle"
                                   TextWrapping="Wrap" />

                        <Border Background="#EEF0F4" CornerRadius="6" Padding="24">
                            <Border Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="2" Padding="26" ClipToBounds="True"
                                    HorizontalAlignment="Center" VerticalAlignment="Top"
                                    BoxShadow="0 2 10 0 #22000000"
                                    Width="{Binding IsLandscape, Converter={StaticResource LandscapeToPageSize}, ConverterParameter=width}"
                                    Height="{Binding IsLandscape, Converter={StaticResource LandscapeToPageSize}, ConverterParameter=height}">
                                <StackPanel Spacing="4">
                                    <TextBox Classes="protocol-inline" Text="{Binding Subtitle, Mode=TwoWay}"
                                             PlaceholderText="{Binding SubtitlePlaceholder}"
                                             FontSize="12" TextAlignment="Center"
                                             AcceptsReturn="True" TextWrapping="Wrap" />
                                    <TextBox Classes="protocol-inline" Text="{Binding CompetitionName, Mode=TwoWay}"
                                             PlaceholderText="{Binding CompetitionNamePlaceholder}"
                                             FontSize="12" TextAlignment="Center"
                                             AcceptsReturn="True" TextWrapping="Wrap" />
                                    <TextBox Classes="protocol-inline" Text="{Binding Title, Mode=TwoWay}"
                                             PlaceholderText="{Binding Localization[SummaryProtocol.DefaultTitle]}"
                                             FontWeight="Bold" FontSize="15" TextAlignment="Center"
                                             AcceptsReturn="True" TextWrapping="Wrap" />
                                    <Grid ColumnDefinitions="*,Auto,*" Margin="0,4,0,0">
                                        <TextBox Grid.Column="0" Classes="protocol-inline" Text="{Binding DateText, Mode=TwoWay}"
                                                 PlaceholderText="{Binding DateTextPlaceholder}"
                                                 FontSize="11" HorizontalAlignment="Left" TextAlignment="Left"
                                                 AcceptsReturn="True" TextWrapping="Wrap" />
                                        <TextBox Grid.Column="1" Classes="protocol-inline" Text="{Binding CompetitionType, Mode=TwoWay}"
                                                 PlaceholderText="{Binding CompetitionTypePlaceholder}"
                                                 FontSize="11" HorizontalAlignment="Center" TextAlignment="Center"
                                                 AcceptsReturn="True" TextWrapping="Wrap" />
                                        <TextBox Grid.Column="2" Classes="protocol-inline" Text="{Binding Venue, Mode=TwoWay}"
                                                 PlaceholderText="{Binding VenuePlaceholder}"
                                                 FontSize="11" HorizontalAlignment="Right" TextAlignment="Right"
                                                 AcceptsReturn="True" TextWrapping="Wrap" />
                                    </Grid>

                                    <TextBlock Text="{Binding Localization[Protocols.Preview.Empty]}" Foreground="#888"
                                               FontStyle="Italic" FontSize="11" Margin="0,10,0,0" TextWrapping="Wrap"
                                               IsVisible="{Binding IsEmpty}" />

                                    <Grid x:Name="PreviewTableHost" Margin="0,8,0,0"
                                          IsVisible="{Binding !IsEmpty}" />
                                </StackPanel>
                            </Border>
                        </Border>

                        <!-- Leading-column visibility — simple checkboxes (reorder by dragging the preview
                             headers). The per-day result bands + «Сума» are fixed at the end and not listed. -->
                        <TextBlock Text="{Binding Localization[SummaryProtocol.Columns.Title]}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Localization[SummaryProtocol.Columns.Hint]}" Classes="subtitle"
                                   TextWrapping="Wrap" />
                        <ItemsControl ItemsSource="{Binding LeadingColumns}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="pages:SummaryColumnItemViewModel">
                                    <CheckBox VerticalAlignment="Center" Margin="0,0,18,6"
                                              IsChecked="{Binding Visible, Mode=TwoWay}"
                                              Content="{Binding Caption}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                                    IsVisible="{Binding SettingsSaved}">
                            <controls:Icon Kind="Check" Size="17"
                                      Foreground="{DynamicResource SuccessBrush}" />
                            <TextBlock Text="{Binding Localization[SummaryProtocol.SavedHint]}"
                                       Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>

</UserControl>

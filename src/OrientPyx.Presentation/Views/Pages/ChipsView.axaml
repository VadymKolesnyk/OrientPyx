<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="using:OrientPyx.Presentation.ViewModels.Pages"
             xmlns:controls="using:OrientPyx.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="940" d:DesignHeight="560"
             x:Class="OrientPyx.Presentation.Views.Pages.ChipsView"
             x:DataType="pages:ChipsViewModel">

    <DockPanel LastChildFill="True">

        <!-- Heading + actions on one line -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="{Binding Title}" Classes="h1"
                           FontSize="{ReflectionBinding TitleFontSize, Source={StaticResource UiScale}}" />
                <TextBlock Text="{Binding Text}" Classes="subtitle" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                        VerticalAlignment="Center">
                <Button Classes="help" Command="{Binding ShowHelpCommand}"
                        ToolTip.Tip="{Binding Localization[Help.Tooltip]}" />
                <Button Command="{Binding ClearChipsCommand}" Classes="ghost danger"
                        ToolTip.Tip="{Binding Localization[Chips.Clear.Hint]}">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <controls:Icon Kind="Trash" Size="15" />
                        <TextBlock Text="{Binding Localization[Chips.Clear]}" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding BulkAddCommand}" Classes="ghost"
                        ToolTip.Tip="{Binding Localization[Chips.BulkAdd.Hint]}">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <controls:Icon Kind="Plus" Size="15" />
                        <TextBlock Text="{Binding Localization[Chips.BulkAdd]}" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding AddChipCommand}" Classes="accent">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <controls:Icon Kind="Plus" Size="15" Foreground="White" />
                        <TextBlock Text="{Binding Localization[Chips.Add]}" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Auto-read panel: watch a readout file and pick up new chips every N seconds. Collapsible. -->
        <Border DockPanel.Dock="Top" Classes="card" Padding="14" Margin="0,0,0,16">
            <StackPanel Spacing="10">

                <!-- Clickable header toggles the body below. The chevron rotates when expanded. -->
                <Button Command="{Binding ToggleAutoReadCommand}" Classes="ghost"
                        Padding="0" HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left" Background="Transparent">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <!-- Chevron: points right when collapsed, down when expanded. -->
                        <controls:Icon Kind="ChevronRight" Size="13"
                                  IsVisible="{Binding !IsAutoReadExpanded}" />
                        <controls:Icon Kind="ChevronDown" Size="13"
                                  IsVisible="{Binding IsAutoReadExpanded}" />
                        <TextBlock Text="{Binding Localization[Chips.AutoRead]}" Classes="h2"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Grid ColumnDefinitions="*,Auto,Auto,Auto" RowDefinitions="Auto,Auto"
                      ColumnSpacing="10" RowSpacing="10"
                      IsVisible="{Binding IsAutoReadExpanded}">

                    <!-- Row 0: file path + picker -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Spacing="4" VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding Localization[Chips.AutoRead.File]}" Classes="label" />
                        <TextBox Text="{Binding AutoReadFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="—" />
                    </StackPanel>
                    <Button Grid.Row="0" Grid.Column="2" Classes="ghost" Click="OnPickFileClick"
                            VerticalAlignment="Bottom"
                            Content="{Binding Localization[Chips.AutoRead.Pick]}" />

                    <!-- Note applied to chips picked up by auto-read -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4"
                                VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding Localization[Chips.AutoRead.Note]}" Classes="label" />
                        <TextBox MinWidth="200"
                                 Text="{Binding AutoReadNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="—" />
                    </StackPanel>

                    <!-- Row 1: interval (custom +/- stepper, not NumericUpDown) + enable toggle -->
                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4" VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding Localization[Chips.AutoRead.Interval]}" Classes="label" />
                        <StackPanel Orientation="Horizontal" Spacing="2">
                            <Button Content="−" Command="{Binding DecrementIntervalCommand}"
                                    Classes="ghost stepper" />
                            <TextBlock Text="{Binding AutoReadIntervalSeconds}" MinWidth="44"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center" FontWeight="Medium" />
                            <Button Content="+" Command="{Binding IncrementIntervalCommand}"
                                    Classes="ghost stepper" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Enable toggle -->
                    <ToggleSwitch Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="3"
                                  VerticalAlignment="Bottom" Margin="12,0,0,0"
                                  IsChecked="{Binding AutoReadEnabled, Mode=TwoWay}"
                                  OnContent="{Binding Localization[Chips.AutoRead.Enabled]}"
                                  OffContent="{Binding Localization[Chips.AutoRead.Enabled]}" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Spreadsheet-style table; the card border supplies the rounded frame. Columns are built in
             code-behind (SheetColumnBuilder) and handed to the shared SheetTable via Bands. -->
        <Border Classes="card" ClipToBounds="True">
            <controls:SheetTable Name="Sheet"
                                 ItemsSource="{Binding Chips}"
                                 Localization="{Binding Localization}"
                                 SelectedItem="{Binding SelectedChip, Mode=TwoWay}"
                                 DeleteRequested="OnDeleteRequested" />
        </Border>

    </DockPanel>

</UserControl>

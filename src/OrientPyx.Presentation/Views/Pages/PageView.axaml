<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="using:OrientPyx.Presentation.ViewModels.Pages"
             mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="460"
             x:Class="OrientPyx.Presentation.Views.Pages.PageView"
             x:DataType="pages:PageViewModelBase">

    <DockPanel LastChildFill="True">

        <!-- Page heading -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,20">
            <TextBlock Grid.Column="0" Text="{Binding Title}" Classes="h1" VerticalAlignment="Center"
                       FontSize="{ReflectionBinding TitleFontSize, Source={StaticResource UiScale}}" />
            <Button Grid.Column="1" Classes="help" Command="{Binding ShowHelpCommand}"
                    ToolTip.Tip="{Binding Localization[Help.Tooltip]}" />
        </Grid>

        <!-- Empty-state card: makes not-yet-built pages look intentional -->
        <Border Classes="card" Padding="40">
            <StackPanel Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420">
                <Border Width="72" Height="72" CornerRadius="36"
                        Background="{DynamicResource AccentSurface}"
                        HorizontalAlignment="Center">
                    <PathIcon Data="{Binding IconData}" Width="34" Height="34"
                              Foreground="{DynamicResource AccentBrush}" />
                </Border>
                <TextBlock Text="{Binding Title}" Classes="h2" HorizontalAlignment="Center"
                           FontSize="{ReflectionBinding SectionFontSize, Source={StaticResource UiScale}}" />
                <TextBlock Text="{Binding Text}" Classes="subtitle"
                           HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
                <Border Classes="badge" HorizontalAlignment="Center" Margin="0,4,0,0">
                    <TextBlock Text="{Binding Localization[Common.ComingSoon]}" />
                </Border>
            </StackPanel>
        </Border>

    </DockPanel>

</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="using:OrientPyx.Presentation.ViewModels.Pages"
             xmlns:controls="using:OrientPyx.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="640"
             x:Class="OrientPyx.Presentation.Views.Pages.StartProtocolsView"
             x:DataType="pages:StartProtocolsViewModel">

    <DockPanel LastChildFill="True">

        <!-- Heading + day picker + generate button -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="{Binding PageTitle}" Classes="h1"
                           FontSize="{ReflectionBinding TitleFontSize, Source={StaticResource UiScale}}" />
                <TextBlock Text="{Binding Text}" Classes="subtitle" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Button Classes="help" Command="{Binding ShowHelpCommand}"
                        ToolTip.Tip="{Binding Localization[Help.Tooltip]}" />
                <controls:SearchableComboBox IsVisible="{Binding ShowDaySelector}"
                          MinWidth="140" VerticalAlignment="Center"
                          SearchWatermark="{Binding Localization[Common.Search]}"
                          ItemsSource="{Binding DayOptions}"
                          SelectedItem="{Binding SelectedDay, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="pages:DayOption">
                            <TextBlock Text="{Binding Label}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </controls:SearchableComboBox>
                <Button Classes="accent" VerticalAlignment="Center"
                        Click="OnGenerateClick"
                        Content="{Binding Localization[Protocols.Generate]}" />
            </StackPanel>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="16" MaxWidth="1180">

                <!-- Layout: orientation -->
                <Border Classes="card" Padding="22">
                    <StackPanel Spacing="14">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Localization[Protocols.Layout.Title]}" Classes="h2"
                                       VerticalAlignment="Center"
                                       FontSize="{ReflectionBinding SectionFontSize, Source={StaticResource UiScale}}" />
                            <Button Classes="help"
                                    Command="{Binding ShowBlockHelpCommand}" CommandParameter="Help.ProtocolLayout"
                                    ToolTip.Tip="{Binding Localization[Help.Tooltip]}" />
                        </StackPanel>
                        <CheckBox IsChecked="{Binding IsLandscape, Mode=TwoWay}"
                                  Content="{Binding Localization[Protocols.Layout.Landscape]}" />
                    </StackPanel>
                </Border>

                <!-- Live document preview (edit the header in place, drag column headers to reorder) -->
                <Border Classes="card" Padding="22">
                    <StackPanel Spacing="14">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Localization[Protocols.Preview.Title]}" Classes="h2"
                                       VerticalAlignment="Center"
                                       FontSize="{ReflectionBinding SectionFontSize, Source={StaticResource UiScale}}" />
                            <Button Classes="help"
                                    Command="{Binding ShowBlockHelpCommand}" CommandParameter="Help.ProtocolPreview"
                                    ToolTip.Tip="{Binding Localization[Help.Tooltip]}" />
                        </StackPanel>
                        <TextBlock Text="{Binding Localization[Protocols.Preview.Hint]}" Classes="subtitle"
                                   TextWrapping="Wrap" />

                        <!-- The document mock-up: a fixed-size page-shaped sheet in true A4 proportions
                             (portrait / landscape). It does NOT resize with content — content that overflows is
                             clipped, just like a printed page. Centred on a soft backdrop like a print preview. -->
                        <Border Background="#EEF0F4" CornerRadius="6" Padding="24">
                            <Border Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="2" Padding="26" ClipToBounds="True"
                                    HorizontalAlignment="Center" VerticalAlignment="Top"
                                    BoxShadow="0 2 10 0 #22000000"
                                    Width="{Binding Preview.IsLandscape, Converter={StaticResource LandscapeToPageSize}, ConverterParameter=width}"
                                    Height="{Binding Preview.IsLandscape, Converter={StaticResource LandscapeToPageSize}, ConverterParameter=height}">
                                <StackPanel Spacing="4">
                                    <!-- Multi-line header fields (Enter inserts a new line). Order, top to bottom:
                                         organising body (subtitle), competition name, then the title — as the
                                         .docx stacks them. -->
                                    <TextBox Classes="protocol-inline" Text="{Binding Subtitle, Mode=TwoWay}"
                                             PlaceholderText="{Binding SubtitlePlaceholder}"
                                             FontSize="12" TextAlignment="Center"
                                             AcceptsReturn="True" TextWrapping="Wrap" />
                                    <TextBox Classes="protocol-inline" Text="{Binding CompetitionName, Mode=TwoWay}"
                                             PlaceholderText="{Binding CompetitionNamePlaceholder}"
                                             FontSize="12" TextAlignment="Center"
                                             AcceptsReturn="True" TextWrapping="Wrap" />
                                    <TextBox Classes="protocol-inline" Text="{Binding Title, Mode=TwoWay}"
                                             PlaceholderText="{Binding TitlePlaceholder}"
                                             FontWeight="Bold" FontSize="15" TextAlignment="Center"
                                             AcceptsReturn="True" TextWrapping="Wrap" />
                                    <Grid ColumnDefinitions="*,Auto,*" Margin="0,4,0,0">
                                        <TextBox Grid.Column="0" Classes="protocol-inline" Text="{Binding DateText, Mode=TwoWay}"
                                                 PlaceholderText="{Binding DateTextPlaceholder}"
                                                 FontSize="11" HorizontalAlignment="Left" TextAlignment="Left"
                                                 AcceptsReturn="True" TextWrapping="Wrap" />
                                        <TextBox Grid.Column="1" Classes="protocol-inline" Text="{Binding CompetitionType, Mode=TwoWay}"
                                                 PlaceholderText="{Binding CompetitionTypePlaceholder}"
                                                 FontSize="11" HorizontalAlignment="Center" TextAlignment="Center"
                                                 AcceptsReturn="True" TextWrapping="Wrap" />
                                        <TextBox Grid.Column="2" Classes="protocol-inline" Text="{Binding Venue, Mode=TwoWay}"
                                                 PlaceholderText="{Binding VenuePlaceholder}"
                                                 FontSize="11" HorizontalAlignment="Right" TextAlignment="Right"
                                                 AcceptsReturn="True" TextWrapping="Wrap" />
                                    </Grid>

                                    <TextBlock Text="{Binding Localization[Protocols.Preview.Empty]}" Foreground="#888"
                                               FontStyle="Italic" FontSize="11" Margin="0,10,0,0" TextWrapping="Wrap"
                                               IsVisible="{Binding Preview.IsEmpty}" />

                                    <!-- The sections + tables are built in code-behind (print-faithful,
                                         header drag-reorder). The page clips overflow, so no inner scroll. -->
                                    <Grid x:Name="PreviewTableHost" Margin="0,8,0,0"
                                          IsVisible="{Binding !Preview.IsEmpty}" />

                                    <!-- Officials' signature block (chief judge / secretary / jury). -->
                                    <ItemsControl ItemsSource="{Binding Preview.Officials}" Margin="60,16,0,0"
                                                  IsVisible="{Binding Preview.HasOfficials}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" FontFamily="Times New Roman"
                                                           FontSize="11" Margin="0,3" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Border>

                        <!-- Column visibility — simple checkboxes (reorder by dragging the preview headers) -->
                        <ItemsControl ItemsSource="{Binding Columns}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="pages:StartProtocolColumnItemViewModel">
                                    <CheckBox VerticalAlignment="Center" Margin="0,0,18,6"
                                              IsChecked="{Binding Visible, Mode=TwoWay}"
                                              Content="{Binding Caption}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Save settings -->
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Content="{Binding Localization[Protocols.SaveSettings]}"
                            Classes="ghost"
                            Command="{Binding SaveSettingsCommand}" />
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                                IsVisible="{Binding SettingsSaved}">
                        <PathIcon Data="M5,12 l4,4 l10,-10" Width="16" Height="16"
                                  Foreground="{DynamicResource SuccessBrush}" />
                        <TextBlock Text="{Binding Localization[Protocols.SettingsSavedHint]}"
                                   Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>

</UserControl>

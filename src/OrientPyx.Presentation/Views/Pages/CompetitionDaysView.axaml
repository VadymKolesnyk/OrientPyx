<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="using:OrientPyx.Presentation.ViewModels.Pages"
             xmlns:controls="using:OrientPyx.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="940" d:DesignHeight="560"
             x:Class="OrientPyx.Presentation.Views.Pages.CompetitionDaysView"
             x:DataType="pages:CompetitionDaysViewModel">

    <DockPanel LastChildFill="True">

        <!-- Heading + add action on one line -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="{Binding Title}" Classes="h1"
                           FontSize="{ReflectionBinding TitleFontSize, Source={StaticResource UiScale}}" />
                <TextBlock Text="{Binding Text}" Classes="subtitle" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                        VerticalAlignment="Center">
                <Button Classes="help" Command="{Binding ShowHelpCommand}"
                        ToolTip.Tip="{Binding Localization[Help.Tooltip]}" />
                <Button Command="{Binding AddDayCommand}" Classes="accent">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <controls:Icon Kind="Plus" Size="15" Foreground="White" />
                        <TextBlock Text="{Binding Localization[CompetitionDays.Add]}" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Spreadsheet-style table; the card border supplies the rounded frame. Columns (including
             the multi-button action cell) are built in code-behind and handed to SheetTable via Bands. -->
        <Border Classes="card" ClipToBounds="True">
            <controls:SheetTable Name="Sheet"
                                 ItemsSource="{Binding Days}"
                                 Localization="{Binding Localization}"
                                 SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                                 LayoutStore="{Binding LayoutStore}"
                                 LayoutKey="competitiondays"
                                 DeleteRequested="OnDeleteRequested" />
        </Border>

    </DockPanel>

</UserControl>

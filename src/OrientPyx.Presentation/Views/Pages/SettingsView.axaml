<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="using:OrientPyx.Presentation.ViewModels.Pages"
             xmlns:controls="using:OrientPyx.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="640" d:DesignHeight="520"
             x:Class="OrientPyx.Presentation.Views.Pages.SettingsView"
             x:DataType="pages:SettingsViewModel">

    <StackPanel Spacing="16" MaxWidth="560">

        <!-- Appearance -->
        <Border Classes="card" Padding="22">
            <StackPanel Spacing="14">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Localization[Settings.InterfaceSize]}" Classes="h2"
                               VerticalAlignment="Center"
                               FontSize="{ReflectionBinding SectionFontSize, Source={StaticResource UiScale}}" />
                    <Button Classes="help"
                            Command="{Binding ShowBlockHelpCommand}" CommandParameter="Help.Settings.Appearance"
                            ToolTip.Tip="{Binding Localization[Help.Tooltip]}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="14">
                    <Slider Minimum="{Binding MinFontScale}"
                            Maximum="{Binding MaxFontScale}"
                            Value="{Binding FontScale, Mode=TwoWay}"
                            TickFrequency="0.1"
                            IsSnapToTickEnabled="True"
                            Width="320"
                            VerticalAlignment="Center" />
                    <Border Classes="badge" VerticalAlignment="Center">
                        <TextBlock Text="{Binding FontScalePercent}" MinWidth="40" TextAlignment="Center" />
                    </Border>
                </StackPanel>

                <TextBlock Text="{Binding Localization[Settings.Language]}" Classes="label" Margin="0,6,0,0" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="{Binding Localization[Settings.Language.Ukrainian]}"
                            Classes="ghost"
                            Command="{Binding SetLanguageCommand}"
                            CommandParameter="uk-UA" />
                    <Button Content="{Binding Localization[Settings.Language.English]}"
                            Classes="ghost"
                            Command="{Binding SetLanguageCommand}"
                            CommandParameter="en-US" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Readout type (timing system) -->
        <Border Classes="card" Padding="22">
            <StackPanel Spacing="14">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Localization[Settings.Readout.Title]}" Classes="h2"
                               VerticalAlignment="Center"
                               FontSize="{ReflectionBinding SectionFontSize, Source={StaticResource UiScale}}" />
                    <Button Classes="help"
                            Command="{Binding ShowBlockHelpCommand}" CommandParameter="Help.Settings.Readout"
                            ToolTip.Tip="{Binding Localization[Help.Tooltip]}" />
                </StackPanel>
                <TextBlock Text="{Binding Localization[Settings.Readout.Hint]}" Classes="muted"
                           TextWrapping="Wrap" />
                <StackPanel Orientation="Horizontal" Spacing="18">
                    <RadioButton GroupName="ReadoutType"
                                 Content="{Binding Localization[Settings.Readout.SportIdent]}"
                                 IsChecked="{Binding IsSportIdent, Mode=TwoWay}" />
                    <RadioButton GroupName="ReadoutType"
                                 Content="{Binding Localization[Settings.Readout.SportTime]}"
                                 IsChecked="{Binding IsSportTime, Mode=TwoWay}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Data paths -->
        <Border Classes="card" Padding="22">
            <StackPanel Spacing="14">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Localization[Settings.Paths]}" Classes="h2"
                               VerticalAlignment="Center"
                               FontSize="{ReflectionBinding SectionFontSize, Source={StaticResource UiScale}}" />
                    <Button Classes="help"
                            Command="{Binding ShowBlockHelpCommand}" CommandParameter="Help.Settings.Paths"
                            ToolTip.Tip="{Binding Localization[Help.Tooltip]}" />
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Localization[Settings.EventsPath]}" Classes="label" />
                    <TextBox Text="{Binding EventsPath, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Content="{Binding Localization[Settings.SavePaths]}"
                            Classes="accent"
                            Command="{Binding SavePathsCommand}" />
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                                IsVisible="{Binding PathsSaved}">
                        <controls:Icon Kind="Check" Size="17"
                                  Foreground="{DynamicResource SuccessBrush}" />
                        <TextBlock Text="{Binding Localization[Settings.PathsSavedHint]}"
                                   Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Online live-results connection (Supabase) -->
        <Border Classes="card" Padding="22">
            <StackPanel Spacing="14">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Localization[Settings.Online.Title]}" Classes="h2"
                               VerticalAlignment="Center"
                               FontSize="{ReflectionBinding SectionFontSize, Source={StaticResource UiScale}}" />
                    <Button Classes="help"
                            Command="{Binding ShowBlockHelpCommand}" CommandParameter="Help.Settings.Online"
                            ToolTip.Tip="{Binding Localization[Help.Tooltip]}" />
                </StackPanel>
                <TextBlock Text="{Binding Localization[Settings.Online.Hint]}" Classes="muted"
                           TextWrapping="Wrap" />

                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Localization[Settings.Online.SupabaseUrl]}" Classes="label" />
                    <TextBox Text="{Binding OnlineSupabaseUrl, Mode=TwoWay}"
                             PlaceholderText="https://xxxxx.supabase.co" />
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Localization[Settings.Online.ServiceKey]}" Classes="label" />
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                        <TextBox Grid.Column="0" Text="{Binding OnlineServiceRoleKey, Mode=TwoWay}"
                                 PasswordChar="{Binding ServiceKeyPasswordChar}" />
                        <!-- Eye toggle: show / hide the secret key -->
                        <Button Grid.Column="1" Classes="ghost" Padding="8,4"
                                Command="{Binding ToggleRevealServiceRoleKeyCommand}"
                                ToolTip.Tip="{Binding Localization[Settings.Online.ServiceKeyReveal]}">
                            <Panel>
                                <controls:Icon Kind="Eye" Size="17" IsVisible="{Binding !RevealServiceRoleKey}" />
                                <controls:Icon Kind="EyeOff" Size="17" IsVisible="{Binding RevealServiceRoleKey}" />
                            </Panel>
                        </Button>
                        <!-- Copy the key to the clipboard -->
                        <Button Grid.Column="2" Classes="ghost" Padding="8,4"
                                Click="OnCopyServiceKeyClick"
                                ToolTip.Tip="{Binding Localization[Settings.Online.ServiceKeyCopy]}">
                            <controls:Icon Kind="Copy" Size="15" />
                        </Button>
                    </Grid>
                    <TextBlock Text="{Binding Localization[Settings.Online.ServiceKeyHint]}" Classes="muted"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Localization[Settings.Online.PublicUrl]}" Classes="label" />
                    <TextBox Text="{Binding OnlinePublicBaseUrl, Mode=TwoWay}"
                             PlaceholderText="https://login.github.io/orientir-results" />
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Localization[Settings.Online.Interval]}" Classes="label" />
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button Content="−" Command="{Binding DecrementOnlineIntervalCommand}"
                                Classes="ghost stepper" />
                        <TextBlock Text="{Binding OnlineIntervalSeconds}" MinWidth="44"
                                   VerticalAlignment="Center" TextAlignment="Center" FontWeight="Medium" />
                        <Button Content="+" Command="{Binding IncrementOnlineIntervalCommand}"
                                Classes="ghost stepper" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Content="{Binding Localization[Settings.Online.Save]}"
                            Classes="accent"
                            Command="{Binding SaveOnlineCommand}" />
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                                IsVisible="{Binding OnlineSaved}">
                        <controls:Icon Kind="Check" Size="17"
                                  Foreground="{DynamicResource SuccessBrush}" />
                        <TextBlock Text="{Binding Localization[Settings.PathsSavedHint]}"
                                   Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Version & updates -->
        <Border Classes="card" Padding="22">
            <StackPanel Spacing="14">
                <TextBlock Text="{Binding Localization[Settings.Update.Title]}" Classes="h2"
                           FontSize="{ReflectionBinding SectionFontSize, Source={StaticResource UiScale}}" />

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding Localization[Settings.Update.Version]}" Classes="label"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding AppVersion}" FontWeight="Medium" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="12" IsVisible="{Binding CanCheckForUpdates}">
                    <Button Content="{Binding Localization[Settings.Update.Check]}"
                            Classes="ghost"
                            IsVisible="{Binding !HasPendingUpdate}"
                            Command="{Binding CheckForUpdatesCommand}" />
                    <Button Content="{Binding Localization[Settings.Update.Install]}"
                            Classes="accent"
                            IsVisible="{Binding HasPendingUpdate}"
                            Command="{Binding DownloadUpdateCommand}" />
                    <TextBlock Text="{Binding UpdateStatus}" Classes="muted" VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Text="{Binding Localization[Settings.Update.DevHint]}" Classes="muted"
                           TextWrapping="Wrap" IsVisible="{Binding !CanCheckForUpdates}" />
            </StackPanel>
        </Border>

    </StackPanel>

</UserControl>

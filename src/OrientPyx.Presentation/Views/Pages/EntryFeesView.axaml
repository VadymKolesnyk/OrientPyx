<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="using:OrientPyx.Presentation.ViewModels.Pages"
             xmlns:controls="using:OrientPyx.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="980" d:DesignHeight="700"
             x:Class="OrientPyx.Presentation.Views.Pages.EntryFeesView"
             x:DataType="pages:EntryFeesViewModel">

    <!-- The page stacks several tables and forms, so it owns its own ScrollViewer (the ShellView
         does not wrap pages in one). Each SheetTable is left unbounded in height so it grows to fit
         all its rows — these tables are short, so the whole page scrolls instead of each table. -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="20">

            <!-- Heading -->
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="{Binding Title}" Classes="h1"
                               FontSize="{ReflectionBinding TitleFontSize, Source={StaticResource UiScale}}" />
                    <TextBlock Text="{Binding Text}" Classes="subtitle" />
                </StackPanel>
                <Button Grid.Column="1" Classes="help" VerticalAlignment="Center"
                        Command="{Binding ShowHelpCommand}"
                        ToolTip.Tip="{Binding Localization[Help.Tooltip]}" />
            </Grid>

            <!-- 1. Per-group entry fees (shared across all days) -->
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Localization[EntryFees.Groups.Title]}" Classes="h2"
                               VerticalAlignment="Center" />
                    <Button Classes="help"
                            Command="{Binding ShowBlockHelpCommand}" CommandParameter="Help.EntryFees.Groups"
                            ToolTip.Tip="{Binding Localization[Help.Tooltip]}" />
                </StackPanel>
                <Border Classes="card" ClipToBounds="True">
                    <controls:SheetTable Name="GroupFeesSheet"
                                         ItemsSource="{Binding GroupFees}"
                                         Localization="{Binding Localization}" />
                </Border>
            </StackPanel>

            <!-- 2. Raised (late) entry fee — a standalone setting, independent of groups -->
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Localization[EntryFees.Raised.Title]}" Classes="h2"
                               VerticalAlignment="Center" />
                    <Button Classes="help"
                            Command="{Binding ShowBlockHelpCommand}" CommandParameter="Help.EntryFees.Raised"
                            ToolTip.Tip="{Binding Localization[Help.Tooltip]}" />
                </StackPanel>
                <Border Classes="card" Padding="20">
                    <StackPanel Spacing="16">
                        <CheckBox IsChecked="{Binding RaisedFeeEnabled, Mode=TwoWay}"
                                  Content="{Binding Localization[EntryFees.Raised.Enable]}" />
                        <StackPanel Spacing="6" MaxWidth="280" HorizontalAlignment="Left"
                                    IsEnabled="{Binding RaisedFeeEnabled}">
                            <TextBlock Text="{Binding Localization[EntryFees.Raised.Amount]}" Classes="label" />
                            <TextBox Text="{Binding RaisedFeeAmountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="0" HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- 3. Chip rental: a base price/day + note-keyed price overrides -->
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Localization[EntryFees.Chips.Title]}" Classes="h2"
                               VerticalAlignment="Center" />
                    <Button Classes="help"
                            Command="{Binding ShowBlockHelpCommand}" CommandParameter="Help.EntryFees.Chips"
                            ToolTip.Tip="{Binding Localization[Help.Tooltip]}" />
                </StackPanel>
                <Border Classes="card" Padding="20">
                    <StackPanel Spacing="6" MaxWidth="280" HorizontalAlignment="Left">
                        <TextBlock Text="{Binding Localization[EntryFees.Chips.BasePrice]}" Classes="label" />
                        <TextBox Text="{Binding ChipBasePriceText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="0" />
                    </StackPanel>
                </Border>

                <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                    <TextBlock Grid.Column="0" Text="{Binding Localization[EntryFees.Chips.OverridesTitle]}"
                               Classes="label" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Command="{Binding AddChipPriceCommand}" Classes="ghost"
                            ToolTip.Tip="{Binding Localization[EntryFees.ChipPrice.Add.Hint]}">
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                            <controls:Icon Kind="Plus" Size="15" />
                            <TextBlock Text="{Binding Localization[EntryFees.ChipPrice.Add]}" />
                        </StackPanel>
                    </Button>
                </Grid>
                <Border Classes="card" ClipToBounds="True">
                    <controls:SheetTable Name="ChipPricesSheet"
                                         ItemsSource="{Binding ChipPriceOverrides}"
                                         Localization="{Binding Localization}"
                                         SelectedItem="{Binding SelectedChipPrice, Mode=TwoWay}"
                                         DeleteRequested="OnChipPriceDeleteRequested" />
                </Border>
            </StackPanel>

            <!-- 4. Additional discounts -->
            <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Localization[EntryFees.Discounts.Title]}"
                                   Classes="h2" VerticalAlignment="Center" />
                        <Button Classes="help"
                                Command="{Binding ShowBlockHelpCommand}" CommandParameter="Help.EntryFees.Discounts"
                                ToolTip.Tip="{Binding Localization[Help.Tooltip]}" />
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding AddDiscountCommand}" Classes="ghost"
                            ToolTip.Tip="{Binding Localization[EntryFees.Discount.Add.Hint]}">
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                            <controls:Icon Kind="Plus" Size="15" />
                            <TextBlock Text="{Binding Localization[EntryFees.Discount.Add]}" />
                        </StackPanel>
                    </Button>
                </Grid>
                <Border Classes="card" ClipToBounds="True">
                    <controls:SheetTable Name="DiscountsSheet"
                                         ItemsSource="{Binding Discounts}"
                                         Localization="{Binding Localization}"
                                         SelectedItem="{Binding SelectedDiscount, Mode=TwoWay}"
                                         DeleteRequested="OnDiscountDeleteRequested" />
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>

</UserControl>

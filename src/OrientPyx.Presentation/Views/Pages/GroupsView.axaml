<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="using:OrientPyx.Presentation.ViewModels.Pages"
             xmlns:controls="using:OrientPyx.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="940" d:DesignHeight="560"
             x:Class="OrientPyx.Presentation.Views.Pages.GroupsView"
             x:DataType="pages:GroupsViewModel">

    <DockPanel LastChildFill="True">

        <!-- Heading + actions. The actions live in a WrapPanel so, when the window is too narrow to
             fit them all on one line, they reflow onto the next row instead of being clipped. -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*" Margin="0,0,0,16">
            <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center"
                        Margin="0,0,16,0">
                <TextBlock Text="{Binding Title}" Classes="h1"
                           FontSize="{ReflectionBinding TitleFontSize, Source={StaticResource UiScale}}" />
                <TextBlock Text="{Binding Text}" Classes="subtitle" />
            </StackPanel>
            <WrapPanel Grid.Column="1" Orientation="Horizontal"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center">
                <Button Classes="help" Command="{Binding ShowHelpCommand}"
                        Margin="0,0,8,8"
                        ToolTip.Tip="{Binding Localization[Help.Tooltip]}" />
                <controls:SearchableComboBox IsVisible="{Binding ShowDaySelector}"
                          MinWidth="120" VerticalAlignment="Center" Margin="0,0,8,8"
                          SearchWatermark="{Binding Localization[Common.Search]}"
                          ItemsSource="{Binding DayOptions}"
                          SelectedItem="{Binding SelectedDay, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="pages:DayOption">
                            <TextBlock Text="{Binding Label}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </controls:SearchableComboBox>
                <Button Name="ImportButton" Classes="ghost" Click="OnImportClick"
                        Margin="0,0,8,8"
                        ToolTip.Tip="{Binding Localization[Import.Hint]}">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <controls:Icon Kind="Upload" Size="15" />
                        <TextBlock Text="{Binding Localization[Import]}" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding RecalculateAgeWindowsCommand}" Classes="ghost"
                        Margin="0,0,8,8"
                        ToolTip.Tip="{Binding Localization[Groups.RecalcAge.Hint]}">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <controls:Icon Kind="RefreshCw" Size="15" />
                        <TextBlock Text="{Binding Localization[Groups.RecalcAge]}" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding PullAllGroupsCommand}" Classes="ghost"
                        Margin="0,0,8,8"
                        ToolTip.Tip="{Binding Localization[Groups.PullAll.Hint]}">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <controls:Icon Kind="Upload" Size="15" />
                        <TextBlock Text="{Binding Localization[Groups.PullAll]}" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding AddGroupCommand}" Classes="accent"
                        Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <controls:Icon Kind="Plus" Size="15" Foreground="White" />
                        <TextBlock Text="{Binding Localization[Groups.Add]}" />
                    </StackPanel>
                </Button>
            </WrapPanel>
        </Grid>

        <!-- Competition-wide defaults, editable above the table (collapsible card — same pattern as the
             finish-read auto-read panel). The global course-setter (начальник дистанції) and the default
             points rule; a group may override either per day. The fields WrapPanel so a narrow window
             reflows them onto another line instead of pushing the controls off-screen. -->
        <Border DockPanel.Dock="Top" Classes="card" Padding="14" Margin="0,0,0,16">
            <StackPanel Spacing="10">

                <Button Command="{Binding ToggleGlobalSettingsCommand}" Classes="ghost"
                        Padding="0" HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left" Background="Transparent">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <controls:Icon Kind="ChevronRight" Size="13"
                                  IsVisible="{Binding !IsGlobalSettingsExpanded}" />
                        <controls:Icon Kind="ChevronDown" Size="13"
                                  IsVisible="{Binding IsGlobalSettingsExpanded}" />
                        <TextBlock Text="{Binding Localization[Groups.GlobalSettings]}" Classes="h2"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <WrapPanel Orientation="Horizontal" IsVisible="{Binding IsGlobalSettingsExpanded}">
                    <!-- Course-setter (name + category) -->
                    <StackPanel Spacing="4" Margin="0,0,28,8" VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding Localization[Groups.GlobalSettings.CourseSetter]}" Classes="label" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox Width="200"
                                     Text="{Binding DefaultCourseSetter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox Width="110"
                                     PlaceholderText="{Binding Localization[Groups.Col.CourseSetterCategory]}"
                                     Text="{Binding DefaultCourseSetterCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Default points rule -->
                    <StackPanel Spacing="4" Margin="0,0,0,8" VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding Localization[Groups.GlobalSettings.DefaultPoints]}" Classes="label" />
                        <ComboBox Width="220"
                                  ItemsSource="{Binding DefaultPointsRuleOptions}"
                                  SelectedItem="{Binding SelectedDefaultPointsRule, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="pages:PointsRuleOption">
                                    <TextBlock Text="{Binding Label}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Grid + a resizable bottom editor for the selected group's course / control list.
             Row 0 (the table) takes the remaining space; the GridSplitter on row 1 drags the
             editor (row 2) taller/shorter. The editor's starting height is fixed but user-resizable. -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="80" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="160" MinHeight="64" />
            </Grid.RowDefinitions>

        <!-- Spreadsheet-style table; the card border supplies the rounded frame. Columns are built
             in code-behind (SheetColumnBuilder) and handed to the shared SheetTable via Bands. -->
        <Border Grid.Row="0" Classes="card" ClipToBounds="True">
            <controls:SheetTable Name="Sheet"
                                 ItemsSource="{Binding Groups}"
                                 Localization="{Binding Localization}"
                                 SelectedItem="{Binding SelectedGroup, Mode=TwoWay}"
                                 LayoutStore="{Binding LayoutStore}"
                                 LayoutKey="groups"
                                 DeleteRequested="OnDeleteRequested" />
        </Border>

        <!-- Vertical resizer between the table and the course editor. -->
        <GridSplitter Grid.Row="1"
                      Height="6"
                      Margin="0,6"
                      HorizontalAlignment="Stretch"
                      ResizeDirection="Rows"
                      Background="Transparent" />

        <!-- Large editor for the selected group's course / control list. Disabled (and showing a
             hint caption) until a group is selected. Row 2 carries the height; the GridSplitter
             above adjusts that row, and the Border stretches to fill it. -->
        <Border Grid.Row="2" Classes="card" Padding="12">
            <DockPanel LastChildFill="True">
                <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="2,0,0,8">
                    <TextBlock Grid.Column="0"
                               Text="{Binding SelectedCourseHeader}"
                               Classes="subtitle"
                               VerticalAlignment="Center" />
                    <!-- Help: how to write the «mixed» order pattern (< >, [N: …], nesting). Shown only
                         for a mixed-discipline group (same condition as the pattern preview below). -->
                    <Button Grid.Column="1" Classes="ghost"
                            Padding="8,2"
                            IsVisible="{Binding IsPatternPreviewVisible}"
                            Command="{Binding ShowCoursePatternHelpCommand}"
                            ToolTip.Tip="{Binding Localization[CoursePattern.Help.Title]}">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <controls:Icon Kind="CircleHelp" Size="15" />
                            <TextBlock Text="{Binding Localization[CoursePattern.Help.Button]}" />
                        </StackPanel>
                    </Button>
                </Grid>
                <!-- Live validation of the «mixed» order pattern: a ✔ with the normalized "S … F" order
                     when valid, or a ✖ with the first structural error when not. Shown only for a
                     mixed-discipline group; the TextBox fills the space above. -->
                <Border DockPanel.Dock="Bottom"
                        IsVisible="{Binding IsPatternPreviewVisible}"
                        Margin="0,8,0,0" Padding="10,7" CornerRadius="6"
                        Background="{DynamicResource SurfaceSubtle}">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <!-- Valid: green check / Invalid: red cross. Glyphs (not PathIcon, which fills an
                             open stroke into a sliver) so they render crisply. -->
                        <TextBlock IsVisible="{Binding IsPatternValid}"
                                   Text="✓" FontWeight="Bold" FontSize="15"
                                   Foreground="#16A34A" VerticalAlignment="Center" />
                        <TextBlock IsVisible="{Binding !IsPatternValid}"
                                   Text="✕" FontWeight="Bold" FontSize="15"
                                   Foreground="#DC2626" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding PatternPreviewText}"
                                   TextWrapping="Wrap" VerticalAlignment="Center"
                                   FontFamily="Consolas, 'Courier New', monospace" />
                    </StackPanel>
                </Border>
                <!-- Scatter («розсіювання») variants editor: the shared SheetTable (Код / Дистанція) shown
                     only for a scatter group (instead of the single course-order box). Each row is one valid
                     order; edits debounce-save the whole set. Columns are built in code-behind. -->
                <DockPanel LastChildFill="True"
                           IsVisible="{Binding IsScatterEditorVisible}">
                    <TextBlock DockPanel.Dock="Top"
                               Text="{Binding Localization[Groups.Scatter.Hint]}"
                               Classes="muted" TextWrapping="Wrap" Margin="2,0,0,8" />
                    <Button DockPanel.Dock="Bottom"
                            Classes="ghost"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0"
                            Content="{Binding Localization[Groups.Scatter.Add]}"
                            Command="{Binding AddScatterVariantCommand}" />
                    <TextBlock DockPanel.Dock="Bottom"
                               Classes="muted"
                               Margin="2,8,0,0"
                               TextWrapping="Wrap"
                               IsVisible="{Binding HasNoScatterVariants}"
                               Text="{Binding Localization[Groups.Scatter.Empty]}" />
                    <Border Classes="card" ClipToBounds="True">
                        <controls:SheetTable Name="ScatterSheet"
                                             ItemsSource="{Binding ScatterVariants}"
                                             Localization="{Binding Localization}"
                                             DeleteRequested="OnScatterDeleteRequested" />
                    </Border>
                </DockPanel>

                <!-- Single course-order box for every non-scatter discipline. -->
                <TextBox AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalContentAlignment="Top"
                         IsVisible="{Binding !IsScatterEditorVisible}"
                         IsEnabled="{Binding HasSelectedGroup}"
                         PlaceholderText="{Binding Localization[Groups.SelectedCourse.Placeholder]}"
                         Text="{Binding SelectedGroup.CourseOrder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, FallbackValue=''}" />
            </DockPanel>
        </Border>

        </Grid>

    </DockPanel>

</UserControl>

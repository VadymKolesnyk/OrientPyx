<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:OrientPyx.Presentation.Converters"
             x:Class="OrientPyx.Presentation.App"
             RequestedThemeVariant="Light">

    <Application.Styles>
        <FluentTheme />

        <!-- Make popups (dropdowns, calendar, menus) follow the global UI scale -->
        <StyleInclude Source="avares://OrientPyx/Styles/PopupScaling.axaml" />

        <!-- Shared editable sheet table; supports a true two-tier banded header (controls:SheetTable) -->
        <StyleInclude Source="avares://OrientPyx/Styles/SheetTable.axaml" />

        <!-- ============================================================
             OrientPyx design system: shared control styling so screens
             stay consistent without per-View hex codes.
             ============================================================ -->

        <!-- Card-like bordered container -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource SurfaceCard}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="BoxShadow" Value="0 1 3 0 #14000000" />
        </Style>

        <!-- Headings -->
        <Style Selector="TextBlock.h1">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TextBlock.h2">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TextBlock.subtitle">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontWeight" Value="Medium" />
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
        </Style>
        <!-- Keyboard-shortcut hint shown trailing a menu row (e.g. "Ctrl+I"). -->
        <Style Selector="TextBlock.gesture">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="24,0,0,0" />
        </Style>

        <!-- Inputs: softer corners, consistent height -->
        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="10,6" />
        </Style>

        <!-- Inline-editable document text inside the protocol preview "sheet": looks like the printed text
             (black, transparent, no chrome) but is a TextBox so the header can be edited in place. A faint
             background appears on hover/focus to signal it is editable. -->
        <Style Selector="TextBox.protocol-inline">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="3,1" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="CaretBrush" Value="Black" />
        </Style>
        <Style Selector="TextBox.protocol-inline:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#11000000" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="TextBox.protocol-inline:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#0F6D4AFF" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="DatePicker">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="MinHeight" Value="38" />
        </Style>
        <Style Selector="CalendarDatePicker">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="10,6" />
        </Style>

        <!-- Buttons -->
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.accent">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentBrushHover}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <!-- Subtle/secondary button -->
        <Style Selector="Button.ghost">
            <Setter Property="Background" Value="{DynamicResource SurfaceSubtle}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        </Style>
        <!-- Square +/- stepper button used by every custom numeric stepper (draw group count, auto-read
             interval, day count, …). Centres the +/- glyph both ways: the base Button padding (16,8) plus
             the glyphs' own high line metrics pushed the sign toward the top-left, so it's zeroed here and
             the ContentPresenter is forced to centre. Combine with Classes="ghost stepper"; set only Width
             per use if a non-default size is wanted (Height tracks the 38px button min-height). -->
        <Style Selector="Button.stepper">
            <Setter Property="Width" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.stepper /template/ ContentPresenter">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
        <!-- Round "?" help button shown in every page header (opens the per-screen help modal). Small,
             circular, subtle by default; tints to the accent surface on hover. Content is set to "?"
             by the pages so no per-View markup beyond Classes="help" is needed. -->
        <Style Selector="Button.help">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="15" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Background" Value="{DynamicResource SurfaceSubtle}" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Content" Value="?" />
        </Style>
        <Style Selector="Button.help:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentSurface}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        </Style>

        <!-- Flyout/dropdown menu row: transparent, full-width, left-aligned content with a hover tint.
             Used by the grouped action menus (e.g. the Participants «Імпорт» / «Дії» dropdowns). -->
        <Style Selector="Button.menu">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,6" />
            <!-- Stretch the content across the full row so a trailing DockPanel.Dock="Right" gesture
                 hint is pushed to the right edge (left label + right-aligned shortcut). -->
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
        <Style Selector="Button.menu:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceSubtle}" />
        </Style>
        <!-- Clickable stat tile / card: looks like a Border.card but is a Button (navigates on click).
             Left-aligned content, card surface, subtle lift on hover. Used by the dashboard tiles. -->
        <Style Selector="Button.tile">
            <Setter Property="Background" Value="{DynamicResource SurfaceCard}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.tile:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceCard}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        </Style>

        <!-- Small action button used inside table rows -->
        <Style Selector="Button.small">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <!-- Danger (destructive) link-style action -->
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
        </Style>
        <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource DangerSurface}" />
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
        </Style>

        <!-- Badge / pill -->
        <Style Selector="Border.badge">
            <Setter Property="Background" Value="{DynamicResource AccentSurface}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.badge > TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- Top menu: a little more breathing room -->
        <Style Selector="Menu">
            <Setter Property="Background" Value="{DynamicResource SurfaceCard}" />
        </Style>
        <Style Selector="Menu > MenuItem">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontWeight" Value="Medium" />
        </Style>
    </Application.Styles>

    <Application.Resources>
        <!-- Bridges VM DateTimeOffset? to CalendarDatePicker's DateTime? SelectedDate -->
        <conv:DateTimeOffsetToDateTimeConverter x:Key="DateTimeOffsetToDateTime" />

        <!-- Dims grid cells that aren't relevant for a row's discipline -->
        <conv:BoolToOpacityConverter x:Key="BoolToOpacity" />

        <!-- Sizes the protocol document-preview "sheet" to true A4 portrait/landscape proportions
             (ConverterParameter=width / =height) -->
        <conv:LandscapeToPageWidthConverter x:Key="LandscapeToPageSize" />

        <!-- Colours the finish-splits status glyph (✓ green / ✗ red / — muted) -->
        <conv:SplitGlyphBrushConverter x:Key="SplitGlyphBrush" />

        <!-- Dock-toggle button icon for the finish-splits panel (move down / move right) -->
        <conv:SplitDockIconConverter x:Key="SplitDockIcon" />

        <!-- Red-tints a finish-read status cell when the status is not OK -->
        <conv:BoolToDangerBrushConverter x:Key="BoolToDangerBrush" />


        <!-- Palette -->
        <Color x:Key="AccentColor">#7C3AED</Color>
        <Color x:Key="AccentColorHover">#6D28D9</Color>

        <SolidColorBrush x:Key="AccentBrush" Color="#7C3AED" />
        <SolidColorBrush x:Key="AccentBrushHover" Color="#6D28D9" />
        <SolidColorBrush x:Key="AccentSurface" Color="#EDE9FE" />

        <SolidColorBrush x:Key="SurfacePage" Color="#F8FAFC" />
        <SolidColorBrush x:Key="SurfaceCard" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SurfaceSubtle" Color="#F1F5F9" />
        <SolidColorBrush x:Key="SurfaceHeader" Color="#F8FAFC" />

        <SolidColorBrush x:Key="BorderSubtle" Color="#E2E8F0" />
        <SolidColorBrush x:Key="BorderStrong" Color="#CBD5E1" />

        <SolidColorBrush x:Key="TextPrimary" Color="#0F172A" />
        <SolidColorBrush x:Key="TextSecondary" Color="#64748B" />
        <SolidColorBrush x:Key="TextMuted" Color="#94A3B8" />

        <SolidColorBrush x:Key="SuccessBrush" Color="#059669" />
        <SolidColorBrush x:Key="DangerBrush" Color="#DC2626" />
        <SolidColorBrush x:Key="DangerSurface" Color="#FEE2E2" />

        <!-- Make Fluent's accent (selection highlights, accent buttons) match brand.
             These MUST be Color, not SolidColorBrush — Fluent reads them as colors. -->
        <Color x:Key="SystemAccentColor">#7C3AED</Color>
        <Color x:Key="SystemAccentColorLight1">#8B5CF6</Color>
        <Color x:Key="SystemAccentColorLight2">#A78BFA</Color>
        <Color x:Key="SystemAccentColorLight3">#C4B5FD</Color>
        <Color x:Key="SystemAccentColorDark1">#6D28D9</Color>
        <Color x:Key="SystemAccentColorDark2">#5B21B6</Color>
        <Color x:Key="SystemAccentColorDark3">#4C1D95</Color>
    </Application.Resources>

</Application>

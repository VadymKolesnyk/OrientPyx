<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:OrientDesk.Presentation.Controls">

    <!-- ============================================================
         Skin + template for the shared editable sheet table (controls:SheetTable).
         A true two-tier banded header the DataGrid cannot do. The body is a
         virtualized ListBox; the header is built in code into PART_HeaderSlot.
         Wrap in Border.card for the rounded frame, like the sheet grids.
         ============================================================ -->

    <Style Selector="controls|SheetTable">
        <Setter Property="Template">
            <ControlTemplate>
                <!-- The body ListBox owns BOTH scrollbars (vertical + horizontal) so they stay
                     pinned to the visible viewport edges. The header sits in its own clip viewport
                     and its horizontal offset is slaved to the body's scroller in code, so the two
                     scroll left/right in lockstep while the header stays frozen vertically. -->
                <DockPanel LastChildFill="True" MinWidth="200"
                           Background="{DynamicResource SurfaceCard}">
                    <!-- Frozen, code-built banded header. Its own ScrollViewer clips horizontally;
                         scrollbars are hidden — the body drives the offset. -->
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource SurfaceHeader}"
                            BorderBrush="{DynamicResource BorderSubtle}"
                            BorderThickness="0,0,0,1"
                            ClipToBounds="True">
                        <ScrollViewer Name="PART_HeaderScroll"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Disabled">
                            <Decorator Name="PART_HeaderSlot" />
                        </ScrollViewer>
                    </Border>

                    <!-- Virtualized rows. Fills the remaining height; rows align to the top so they
                         sit directly under the header (no centered gap). Owns both scrollbars; the
                         horizontal one drives the header.
                         NOTE: the VirtualizingStackPanel must stretch to fill the ListBox viewport.
                         Giving it VerticalAlignment="Top" sizes it to the content of only the rows
                         realized on the first pass, so the panel never grows to the viewport and the
                         remaining rows are never materialized — the table then shows a subset and
                         shuffles which rows appear when the source is sorted/refiltered. The ListBox
                         already lays its rows out top-down, so stretching the panel keeps them under
                         the header without dropping rows. -->
                    <ListBox Name="PART_Body"
                             Background="Transparent"
                             BorderThickness="0"
                             SelectionMode="Single"
                             VerticalAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                    </ListBox>
                </DockPanel>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- Header sub-cells: dense, header-toned, like the sheet grid headers -->
    <Style Selector="controls|SheetTable Border > TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
        <Setter Property="FontWeight" Value="Medium" />
    </Style>

    <!-- Header band/sub-cell separators: stronger, more visible vertical rules -->
    <Style Selector="controls|SheetTable Grid#PART_HeaderSlot Border">
        <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
        <Setter Property="MinHeight" Value="38" />
    </Style>

    <!-- Sort icon button on the right of each header cell -->
    <Style Selector="controls|SheetTable Button.rosterSort">
        <Setter Property="Width" Value="26" />
        <Setter Property="Height" Value="26" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="controls|SheetTable Button.rosterSort:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BorderSubtle}" />
    </Style>

    <!-- Resize grips in the header: a wide transparent hit zone with a centered grip line that
         strengthens to the accent colour on hover so the draggable edge is discoverable. -->
    <Style Selector="controls|SheetTable Thumb.rosterResize">
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="Transparent">
                    <!-- Right-aligned so the visible line sits exactly on the column's right edge,
                         lining up with the body cell border (not floating left of it). -->
                    <Rectangle Name="grip"
                               Width="2"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Stretch"
                               Margin="0,6"
                               Fill="{DynamicResource BorderStrong}" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="controls|SheetTable Thumb.rosterResize:pointerover /template/ Rectangle#grip">
        <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Width" Value="2.5" />
    </Style>

    <!-- Rows: compact, gridlined like the sheet -->
    <Style Selector="controls|SheetTable ListBoxItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <!-- Cell hosts: vertical gridlines + the focused-cell accent outline (Excel cue) -->
    <Style Selector="controls|SheetTable controls|SheetCell">
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="controls|SheetTable controls|SheetCell:focus">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="1.5" />
    </Style>

    <!-- In-cell editors: borderless, fill the cell, no rounded corners  -->
    <Style Selector="controls|SheetTable controls|SheetCell TextBox">
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="controls|SheetTable controls|SheetCell ComboBox">
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <!-- The ComboBox's content presenter must stretch too, or the control paints its selected text in
         a short intrinsic-height box centred in the cell rather than filling the row's height. -->
    <Style Selector="controls|SheetTable controls|SheetCell ComboBox /template/ ContentControl#ContentPresenter">
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <!-- A date cell edits 1:1 like a text cell (flat, borderless input, no height jump). The picker's
         templated parts (inner PART_TextBox, its PART_BorderElement, and the PART_Button glyph) each
         carry the app-wide MinHeight=38, which grows the row. Those parts live two template levels deep
         and a "SheetCell CalendarDatePicker /template/ …" selector does NOT reach them, so the flattening
         is done in code in LazyDateCell.OnPickerTemplateApplied. This picker-level style only handles the
         outer chrome (borders/background) that the selector can reach. -->
    <Style Selector="controls|SheetTable controls|SheetCell CalendarDatePicker">
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

</Styles>

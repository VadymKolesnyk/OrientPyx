<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dialogs="using:OrientDesk.Presentation.ViewModels.Dialogs"
             mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="280"
             x:Class="OrientDesk.Presentation.Views.Dialogs.ExportFormatView"
             x:DataType="dialogs:ExportFormatViewModel">

    <!-- Centered card; the backdrop is supplied by the host overlay. -->
    <Border Background="{DynamicResource SurfaceCard}"
            CornerRadius="12"
            MinWidth="380" MaxWidth="460"
            BoxShadow="0 10 40 0 #40000000"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            ClipToBounds="True">
        <DockPanel LastChildFill="True">

            <!-- Header -->
            <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceCard}"
                    BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,0,0,1"
                    Padding="22,16">
                <TextBlock Text="{Binding Title}" Classes="h2" VerticalAlignment="Center" />
            </Border>

            <!-- Footer actions -->
            <Border DockPanel.Dock="Bottom" Background="{DynamicResource SurfaceCard}"
                    BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,1,0,0"
                    Padding="22,14">
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                    <Button Content="{Binding Localization[Common.Cancel]}"
                            Classes="ghost"
                            Command="{Binding CancelCommand}" />
                    <Button Content="{Binding Localization[Export.Confirm]}"
                            Classes="accent"
                            Command="{Binding ConfirmCommand}" />
                </StackPanel>
            </Border>

            <!-- Body -->
            <StackPanel Margin="22,18" Spacing="14">
                <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondary}" />

                <StackPanel Spacing="8">
                    <RadioButton GroupName="ExportFormat"
                                 Content="{Binding ExcelLabel}"
                                 IsChecked="{Binding IsExcel, Mode=TwoWay}" />
                    <RadioButton GroupName="ExportFormat"
                                 Content="{Binding CsvLabel}"
                                 IsChecked="{Binding IsCsv, Mode=TwoWay}" />
                </StackPanel>
            </StackPanel>

        </DockPanel>
    </Border>

</UserControl>

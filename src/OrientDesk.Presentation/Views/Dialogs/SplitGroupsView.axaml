<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dialogs="using:OrientDesk.Presentation.ViewModels.Dialogs"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="620"
             x:Class="OrientDesk.Presentation.Views.Dialogs.SplitGroupsView"
             x:DataType="dialogs:SplitGroupsViewModel">

    <!-- Centered card; the backdrop is supplied by the host overlay. Wide and tall so the
         course/group grid uses the available space and needs little scrolling. -->
    <Border Background="{DynamicResource SurfaceCard}"
            CornerRadius="12"
            Width="900" MaxWidth="980"
            MaxHeight="760"
            BoxShadow="0 10 40 0 #40000000"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            ClipToBounds="True">
        <DockPanel LastChildFill="True">

            <!-- Header -->
            <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceCard}"
                    BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,0,0,1"
                    Padding="24,18">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding Title}" Classes="h2" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Message}" Classes="muted" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Footer actions -->
            <Border DockPanel.Dock="Bottom" Background="{DynamicResource SurfaceCard}"
                    BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,1,0,0"
                    Padding="24,14">
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                    <Button Content="{Binding Localization[Common.Cancel]}"
                            Classes="ghost"
                            Command="{Binding CancelCommand}" />
                    <Button Content="{Binding Localization[Split.Continue]}"
                            Classes="accent"
                            Command="{Binding ConfirmCommand}" />
                </StackPanel>
            </Border>

            <!-- Body: a row per parsed course. Left = original name (fixed column);
                 right = the editable split groups flowing in a wrap panel, so two or three
                 groups sit side by side instead of stacking. -->
            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto"
                          Padding="0,4">
                <ItemsControl ItemsSource="{Binding Courses}" Margin="24,8">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="dialogs:SplitCourseRow">
                            <Border BorderBrush="{DynamicResource BorderSubtle}"
                                    BorderThickness="0,0,0,1" Padding="0,12">
                                <Grid ColumnDefinitions="180,*">

                                    <!-- Original course name (heading for the row) -->
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding OriginalName}"
                                               Classes="label" FontWeight="SemiBold"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"
                                               Margin="0,0,16,0" />

                                    <!-- Split groups: each a compact chip; add button trails inline. -->
                                    <StackPanel Grid.Column="1" Spacing="8">
                                        <ItemsControl ItemsSource="{Binding Groups}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="dialogs:SplitGroupEntry">
                                                    <Border Background="{DynamicResource SurfaceSubtle}"
                                                            CornerRadius="6"
                                                            Padding="4"
                                                            Margin="0,0,8,8">
                                                        <StackPanel Orientation="Horizontal" Spacing="2"
                                                                    VerticalAlignment="Center">
                                                            <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                     Width="96"
                                                                     BorderThickness="0"
                                                                     Background="Transparent"
                                                                     Padding="6,4"
                                                                     VerticalContentAlignment="Center" />
                                                            <Button Content="✕"
                                                                    Classes="ghost"
                                                                    Padding="6,0" FontSize="12"
                                                                    VerticalAlignment="Stretch"
                                                                    Command="{Binding $parent[ItemsControl].((dialogs:SplitCourseRow)DataContext).RemoveGroupCommand}"
                                                                    CommandParameter="{Binding}" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <Button Content="{Binding AddGroupLabel}"
                                                Classes="ghost"
                                                Padding="8,4" FontSize="13"
                                                HorizontalAlignment="Left"
                                                Command="{Binding AddGroupCommand}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </DockPanel>
    </Border>

</UserControl>

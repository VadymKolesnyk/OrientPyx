<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dialogs="using:OrientDesk.Presentation.ViewModels.Dialogs"
             mc:Ignorable="d" d:DesignWidth="560" d:DesignHeight="620"
             x:Class="OrientDesk.Presentation.Views.Dialogs.CoursePatternHelpView"
             x:DataType="dialogs:CoursePatternHelpViewModel">

    <UserControl.Styles>
        <!-- Section heading (no global h3 class exists — define it locally). -->
        <Style Selector="TextBlock.h3">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <!-- Monospace, boxed code samples so the bracket patterns line up and read as literals. -->
        <Style Selector="TextBlock.code">
            <Setter Property="FontFamily" Value="Consolas, 'Courier New', monospace" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="Border.codebox">
            <Setter Property="Background" Value="{DynamicResource SurfaceSubtle}" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
    </UserControl.Styles>

    <!-- Centered card; the backdrop is supplied by the host overlay. -->
    <Border Background="{DynamicResource SurfaceCard}"
            CornerRadius="12"
            MinWidth="480" MaxWidth="620"
            BoxShadow="0 10 40 0 #40000000"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            ClipToBounds="True"
            KeyboardNavigation.TabNavigation="Cycle">
        <DockPanel LastChildFill="True">

            <!-- Header -->
            <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceCard}"
                    BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,0,0,1"
                    Padding="22,16">
                <TextBlock Text="{Binding Localization[CoursePattern.Help.Title]}" Classes="h2"
                           VerticalAlignment="Center" />
            </Border>

            <!-- Footer -->
            <Border DockPanel.Dock="Bottom" Background="{DynamicResource SurfaceCard}"
                    BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,1,0,0"
                    Padding="22,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{Binding Localization[CoursePattern.Help.Close]}"
                            Classes="accent"
                            IsDefault="True" IsCancel="True"
                            Command="{Binding CloseCommand}" />
                </StackPanel>
            </Border>

            <!-- Body -->
            <ScrollViewer MaxHeight="480" HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="22,18" Spacing="14">

                    <TextBlock Text="{Binding Localization[CoursePattern.Help.Intro]}"
                               TextWrapping="Wrap" Classes="muted" />

                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding Localization[CoursePattern.Help.SeqTitle]}" Classes="h3" />
                        <TextBlock Text="{Binding Localization[CoursePattern.Help.SeqBody]}"
                                   TextWrapping="Wrap" Classes="muted" />
                        <Border Classes="codebox">
                            <TextBlock Classes="code" Text="{Binding Localization[CoursePattern.Help.SeqExample]}" />
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding Localization[CoursePattern.Help.AnyTitle]}" Classes="h3" />
                        <TextBlock Text="{Binding Localization[CoursePattern.Help.AnyBody]}"
                                   TextWrapping="Wrap" Classes="muted" />
                        <Border Classes="codebox">
                            <TextBlock Classes="code" Text="{Binding Localization[CoursePattern.Help.AnyExample]}" />
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding Localization[CoursePattern.Help.MarkersTitle]}" Classes="h3" />
                        <TextBlock Text="{Binding Localization[CoursePattern.Help.MarkersBody]}"
                                   TextWrapping="Wrap" Classes="muted" />
                        <Border Classes="codebox">
                            <TextBlock Classes="code" Text="{Binding Localization[CoursePattern.Help.MarkersExample]}" />
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding Localization[CoursePattern.Help.NestTitle]}" Classes="h3" />
                        <TextBlock Text="{Binding Localization[CoursePattern.Help.NestBody]}"
                                   TextWrapping="Wrap" Classes="muted" />
                        <Border Classes="codebox">
                            <TextBlock Classes="code" Text="{Binding Localization[CoursePattern.Help.NestExample]}" />
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding Localization[CoursePattern.Help.NotesTitle]}" Classes="h3" />
                        <TextBlock Text="{Binding Localization[CoursePattern.Help.NotesBody]}"
                                   TextWrapping="Wrap" Classes="muted" />
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

        </DockPanel>
    </Border>

</UserControl>

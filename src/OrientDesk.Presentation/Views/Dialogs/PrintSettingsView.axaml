<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dialogs="using:OrientDesk.Presentation.ViewModels.Dialogs"
             mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="300"
             x:Class="OrientDesk.Presentation.Views.Dialogs.PrintSettingsView"
             x:DataType="dialogs:PrintSettingsViewModel">

    <!-- Centered card; the backdrop is supplied by the host overlay. -->
    <Border Background="{DynamicResource SurfaceCard}"
            CornerRadius="12"
            MinWidth="380" MaxWidth="460"
            BoxShadow="0 10 40 0 #40000000"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            ClipToBounds="True">
        <DockPanel LastChildFill="True">

            <!-- Header -->
            <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceCard}"
                    BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,0,0,1"
                    Padding="22,16">
                <TextBlock Text="{Binding Title}" Classes="h2" VerticalAlignment="Center" />
            </Border>

            <!-- Footer actions -->
            <Border DockPanel.Dock="Bottom" Background="{DynamicResource SurfaceCard}"
                    BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,1,0,0"
                    Padding="22,14">
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                    <Button Content="{Binding Localization[Common.Cancel]}"
                            Classes="ghost"
                            Command="{Binding CancelCommand}" />
                    <Button Content="{Binding Localization[Print.Settings.Save]}"
                            Classes="accent"
                            IsEnabled="{Binding IsSupported}"
                            Command="{Binding ConfirmCommand}" />
                </StackPanel>
            </Border>

            <!-- Body -->
            <StackPanel Margin="22,18" Spacing="14">

                <!-- Unsupported note (non-Windows): printing is not available, the form is disabled. -->
                <TextBlock Text="{Binding UnsupportedNote}"
                           IsVisible="{Binding !IsSupported}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource DangerBrush}" />

                <StackPanel Spacing="6" IsEnabled="{Binding IsSupported}">
                    <TextBlock Text="{Binding PrinterLabel}" Classes="label" />
                    <ComboBox ItemsSource="{Binding Printers}"
                              SelectedItem="{Binding SelectedPrinter, Mode=TwoWay}"
                              HorizontalAlignment="Stretch" />
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding WidthLabel}" Classes="label" />
                    <ComboBox ItemsSource="{Binding Widths}"
                              SelectedItem="{Binding SelectedWidth, Mode=TwoWay}"
                              HorizontalAlignment="Stretch" />
                </StackPanel>

            </StackPanel>

        </DockPanel>
    </Border>

</UserControl>

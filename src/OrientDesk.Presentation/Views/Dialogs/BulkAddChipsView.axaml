<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dialogs="using:OrientDesk.Presentation.ViewModels.Dialogs"
             xmlns:behaviors="using:OrientDesk.Presentation.Behaviors"
             mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="320"
             x:Class="OrientDesk.Presentation.Views.Dialogs.BulkAddChipsView"
             x:DataType="dialogs:BulkAddChipsViewModel">

    <!-- Centered card; the backdrop is supplied by the host overlay. -->
    <Border Background="{DynamicResource SurfaceCard}"
            CornerRadius="12"
            MinWidth="380" MaxWidth="460"
            BoxShadow="0 10 40 0 #40000000"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            ClipToBounds="True">
        <DockPanel LastChildFill="True">

            <!-- Header -->
            <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceCard}"
                    BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,0,0,1"
                    Padding="22,16">
                <TextBlock Text="{Binding Title}" Classes="h2" VerticalAlignment="Center" />
            </Border>

            <!-- Footer actions -->
            <Border DockPanel.Dock="Bottom" Background="{DynamicResource SurfaceCard}"
                    BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,1,0,0"
                    Padding="22,14">
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                    <Button Content="{Binding Localization[Common.Cancel]}"
                            Classes="ghost"
                            Command="{Binding CancelCommand}" />
                    <Button Content="{Binding Localization[Common.Ok]}"
                            Classes="accent"
                            Command="{Binding ConfirmCommand}" />
                </StackPanel>
            </Border>

            <!-- Body -->
            <StackPanel Margin="22,18" Spacing="14">

                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Localization[Chips.BulkAdd.Start]}" Classes="label" />
                    <TextBox Text="{Binding StartNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             behaviors:NumericInput.Integer="True"
                             PlaceholderText="9007400" />
                </StackPanel>

                <!-- Count: a custom +/- stepper, not NumericUpDown (its Windows automation peer
                     crashes on spin). Same shape as the day-count stepper in CreateEventView. -->
                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Localization[Chips.BulkAdd.Count]}" Classes="label" />
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button Content="−" Command="{Binding DecrementCommand}"
                                Width="36" Classes="ghost" Padding="0"
                                HorizontalContentAlignment="Center" />
                        <TextBlock Text="{Binding Count}" MinWidth="44"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center" FontWeight="Medium" />
                        <Button Content="+" Command="{Binding IncrementCommand}"
                                Width="36" Classes="ghost" Padding="0"
                                HorizontalContentAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Localization[Chips.BulkAdd.Note]}" Classes="label" />
                    <TextBox Text="{Binding Note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="—" />
                </StackPanel>

            </StackPanel>

        </DockPanel>
    </Border>

</UserControl>

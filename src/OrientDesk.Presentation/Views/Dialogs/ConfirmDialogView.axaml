<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dialogs="using:OrientDesk.Presentation.ViewModels.Dialogs"
             mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="200"
             x:Class="OrientDesk.Presentation.Views.Dialogs.ConfirmDialogView"
             x:DataType="dialogs:ConfirmDialogViewModel">

    <UserControl.Styles>
        <!-- Make the keyboard-focused footer button unmistakable: a thick accent ring around the
             button content. Tab / arrow keys move focus between the two buttons; Enter runs the
             focused one. Drawn for :focus-visible (keyboard focus) only, not on mouse clicks. -->
        <Style Selector="StackPanel.dialog-actions > Button:focus-visible /template/ ContentPresenter">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
    </UserControl.Styles>

    <!-- Centered card; the backdrop is supplied by the host overlay.
         TabNavigation=Cycle traps Tab inside the dialog: focus cycles between Cancel and Confirm
         and never leaks to the window behind the modal. -->
    <Border Background="{DynamicResource SurfaceCard}"
            CornerRadius="12"
            MinWidth="380" MaxWidth="460"
            BoxShadow="0 10 40 0 #40000000"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            ClipToBounds="True"
            KeyboardNavigation.TabNavigation="Cycle">
        <DockPanel LastChildFill="True">

            <!-- Header -->
            <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceCard}"
                    BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,0,0,1"
                    Padding="22,16">
                <TextBlock Text="{Binding Title}" Classes="h2" VerticalAlignment="Center" />
            </Border>

            <!-- Footer actions -->
            <Border DockPanel.Dock="Bottom" Background="{DynamicResource SurfaceCard}"
                    BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,1,0,0"
                    Padding="22,14">
                <StackPanel Classes="dialog-actions"
                            Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                    <Button Content="{Binding CancelText}"
                            Classes="ghost"
                            IsCancel="True"
                            Command="{Binding CancelCommand}" />
                    <Button Name="ConfirmButton"
                            Content="{Binding ConfirmText}"
                            Classes="danger"
                            IsDefault="True"
                            Command="{Binding ConfirmCommand}" />
                </StackPanel>
            </Border>

            <!-- Body: message -->
            <StackPanel Margin="22,18">
                <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Classes="muted" />
            </StackPanel>

        </DockPanel>
    </Border>

</UserControl>

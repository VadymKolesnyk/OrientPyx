<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="using:OrientDesk.Presentation.ViewModels.Pages"
             xmlns:controls="using:OrientDesk.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="940" d:DesignHeight="560"
             x:Class="OrientDesk.Presentation.Views.Pages.FinishReadView"
             x:DataType="pages:FinishReadViewModel">

    <DockPanel LastChildFill="True">

        <!-- Heading + day picker on one line -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="{Binding Title}" Classes="h1"
                           FontSize="{ReflectionBinding TitleFontSize, Source={StaticResource UiScale}}" />
                <TextBlock Text="{Binding Text}" Classes="subtitle" />
            </StackPanel>
            <controls:SearchableComboBox Grid.Column="1" IsVisible="{Binding ShowDaySelector}"
                      MinWidth="140" VerticalAlignment="Center"
                      SearchWatermark="{Binding Localization[Common.Search]}"
                      ItemsSource="{Binding DayOptions}"
                      SelectedItem="{Binding SelectedDay, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="pages:DayOption">
                        <TextBlock Text="{Binding Label}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </controls:SearchableComboBox>
        </Grid>

        <!-- Auto-read panel: watch a finish readout file and append new reads every N seconds. Collapsible. -->
        <Border DockPanel.Dock="Top" Classes="card" Padding="14" Margin="0,0,0,16">
            <StackPanel Spacing="10">

                <Button Command="{Binding ToggleAutoReadCommand}" Classes="ghost"
                        Padding="0" HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left" Background="Transparent">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <PathIcon Data="M8,5 l8,7 l-8,7" Width="12" Height="12"
                                  IsVisible="{Binding !IsAutoReadExpanded}" />
                        <PathIcon Data="M5,8 l7,8 l7,-8" Width="12" Height="12"
                                  IsVisible="{Binding IsAutoReadExpanded}" />
                        <TextBlock Text="{Binding Localization[FinishRead.AutoRead]}" Classes="h2"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto"
                      ColumnSpacing="10" RowSpacing="10"
                      IsVisible="{Binding IsAutoReadExpanded}">

                    <!-- File path + picker -->
                    <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding Localization[FinishRead.AutoRead.File]}" Classes="label" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox MinWidth="320"
                                     Text="{Binding AutoReadFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="—" />
                            <Button Classes="ghost" Click="OnPickFileClick"
                                    VerticalAlignment="Bottom"
                                    Content="{Binding Localization[FinishRead.AutoRead.Pick]}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Interval stepper -->
                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding Localization[FinishRead.AutoRead.Interval]}" Classes="label" />
                        <StackPanel Orientation="Horizontal" Spacing="2">
                            <Button Content="−" Command="{Binding DecrementIntervalCommand}"
                                    Width="36" Classes="ghost" Padding="0"
                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
                            <TextBlock Text="{Binding AutoReadIntervalSeconds}" MinWidth="44"
                                       VerticalAlignment="Center" TextAlignment="Center" FontWeight="Medium" />
                            <Button Content="+" Command="{Binding IncrementIntervalCommand}"
                                    Width="36" Classes="ghost" Padding="0"
                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Enable toggle -->
                    <ToggleSwitch Grid.Column="2" VerticalAlignment="Bottom" Margin="12,0,0,0"
                                  IsChecked="{Binding AutoReadEnabled, Mode=TwoWay}"
                                  OnContent="{Binding Localization[FinishRead.AutoRead.Enabled]}"
                                  OffContent="{Binding Localization[FinishRead.AutoRead.Enabled]}" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Read-only log table; columns built in code-behind. -->
        <Border Classes="card" ClipToBounds="True">
            <controls:SheetTable Name="Sheet"
                                 ItemsSource="{Binding Readouts}"
                                 Localization="{Binding Localization}" />
        </Border>

    </DockPanel>

</UserControl>

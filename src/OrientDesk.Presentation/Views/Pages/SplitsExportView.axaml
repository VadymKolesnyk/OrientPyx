<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="using:OrientDesk.Presentation.ViewModels.Pages"
             xmlns:controls="using:OrientDesk.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="820" d:DesignHeight="640"
             x:Class="OrientDesk.Presentation.Views.Pages.SplitsExportView"
             x:DataType="pages:SplitsExportViewModel">

    <DockPanel LastChildFill="True">

        <!-- Heading + day picker + export button -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="{Binding Title, FallbackValue=''}" Classes="h1"
                           FontSize="{ReflectionBinding TitleFontSize, Source={StaticResource UiScale}}" />
                <TextBlock Text="{Binding Localization[Page.Splits.Text]}" Classes="subtitle" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <controls:SearchableComboBox IsVisible="{Binding ShowDaySelector}"
                          MinWidth="140" VerticalAlignment="Center"
                          SearchWatermark="{Binding Localization[Common.Search]}"
                          ItemsSource="{Binding DayOptions}"
                          SelectedItem="{Binding SelectedDay, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="pages:DayOption">
                            <TextBlock Text="{Binding Label}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </controls:SearchableComboBox>
                <Button Classes="accent" VerticalAlignment="Center"
                        Click="OnGenerateClick"
                        Content="{Binding Localization[Splits.Generate]}" />
            </StackPanel>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="16" MaxWidth="720">

                <!-- Header text -->
                <Border Classes="card" Padding="22">
                    <StackPanel Spacing="14">
                        <TextBlock Text="{Binding Localization[Splits.Header.Title]}" Classes="h2"
                                   FontSize="{ReflectionBinding SectionFontSize, Source={StaticResource UiScale}}" />
                        <TextBlock Text="{Binding Localization[Splits.Header.Hint]}" Classes="subtitle"
                                   TextWrapping="Wrap" />

                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding Localization[Splits.Header.MainTitle]}" Classes="label" />
                            <TextBox Text="{Binding Title, Mode=TwoWay}"
                                     PlaceholderText="{Binding TitlePlaceholder}" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding Localization[Splits.Header.Subtitle]}" Classes="label" />
                            <TextBox Text="{Binding Subtitle, Mode=TwoWay}"
                                     PlaceholderText="{Binding SubtitlePlaceholder}" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding Localization[Splits.Header.CompetitionType]}" Classes="label" />
                            <TextBox Text="{Binding CompetitionType, Mode=TwoWay}"
                                     PlaceholderText="{Binding CompetitionTypePlaceholder}" />
                        </StackPanel>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="{Binding Localization[Splits.Header.Date]}" Classes="label" />
                                <TextBox Text="{Binding DateText, Mode=TwoWay}"
                                         PlaceholderText="{Binding DateTextPlaceholder}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="6">
                                <TextBlock Text="{Binding Localization[Splits.Header.Venue]}" Classes="label" />
                                <TextBox Text="{Binding Venue, Mode=TwoWay}"
                                         PlaceholderText="{Binding VenuePlaceholder}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Classes="card" Padding="22">
                    <TextBlock Text="{Binding Localization[Splits.Info]}" Classes="subtitle" TextWrapping="Wrap" />
                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>

</UserControl>

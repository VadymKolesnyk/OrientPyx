<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="using:OrientDesk.Presentation.ViewModels.Pages"
             mc:Ignorable="d" d:DesignWidth="940" d:DesignHeight="560"
             x:Class="OrientDesk.Presentation.Views.Pages.CompetitionDaysView"
             x:DataType="pages:CompetitionDaysViewModel">

    <DockPanel LastChildFill="True">

        <!-- Heading + add action on one line -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="{Binding Title}" Classes="h1"
                           FontSize="{ReflectionBinding TitleFontSize, Source={StaticResource UiScale}}" />
                <TextBlock Text="{Binding Text}" Classes="subtitle" />
            </StackPanel>
            <Button Grid.Column="1" VerticalAlignment="Center"
                    Command="{Binding AddDayCommand}" Classes="accent">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <PathIcon Data="M12,5 v14 M5,12 h14" Width="14" Height="14" Foreground="White" />
                    <TextBlock Text="{Binding Localization[CompetitionDays.Add]}" />
                </StackPanel>
            </Button>
        </Grid>

        <Border Classes="card" ClipToBounds="True">
            <DockPanel LastChildFill="True">
                <!-- Column header -->
                <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceHeader}"
                        BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,0,0,1" Padding="16,11">
                    <Grid ColumnDefinitions="160,2*,3*,3*,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding Localization[CompetitionDays.Col.Day]}" Classes="label" />
                        <TextBlock Grid.Column="1" Text="{Binding Localization[CompetitionDays.Col.Date]}" Classes="label" />
                        <TextBlock Grid.Column="2" Text="{Binding Localization[CompetitionDays.Col.Venue]}" Classes="label" />
                        <TextBlock Grid.Column="3" Text="{Binding Localization[CompetitionDays.Col.Discipline]}" Classes="label" />
                        <TextBlock Grid.Column="4" Text="{Binding Localization[CompetitionDays.Col.Actions]}" Classes="label" MinWidth="250" />
                    </Grid>
                </Border>

                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding Days}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="pages:DayRowViewModel">
                                <Border BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,0,0,1" Padding="16,10"
                                        Classes.active="{Binding IsActive}">
                                    <Border.Styles>
                                        <!-- Subtly tint the active day's row -->
                                        <Style Selector="Border.active">
                                            <Setter Property="Background" Value="{DynamicResource AccentSurface}" />
                                        </Style>
                                    </Border.Styles>
                                    <Grid ColumnDefinitions="160,2*,3*,3*,Auto" VerticalAlignment="Center">
                                        <!-- Day number + active marker -->
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding NumberLabel}" Foreground="{DynamicResource TextPrimary}"
                                                       FontWeight="Medium" VerticalAlignment="Center" />
                                            <Border Classes="badge" IsVisible="{Binding IsActive}">
                                                <TextBlock Text="{Binding Localization[CompetitionDays.Active]}"
                                                           FontSize="{ReflectionBinding SmallFontSize, Source={StaticResource UiScale}}" />
                                            </Border>
                                        </StackPanel>

                                        <DatePicker Grid.Column="1" SelectedDate="{Binding Date, Mode=TwoWay}" Margin="0,0,10,0" />
                                        <TextBox Grid.Column="2" Text="{Binding Venue, Mode=TwoWay}" Margin="0,0,10,0"
                                                 PlaceholderText="—" />
                                        <TextBox Grid.Column="3" Text="{Binding Discipline, Mode=TwoWay}" Margin="0,0,10,0"
                                                 PlaceholderText="—" />

                                        <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <Button Content="{Binding Localization[CompetitionDays.Save]}"
                                                    Classes="ghost small"
                                                    Command="{Binding $parent[ItemsControl].((pages:CompetitionDaysViewModel)DataContext).SaveDayCommand}"
                                                    CommandParameter="{Binding}"
                                                    IsEnabled="{Binding IsDirty}" />
                                            <Button Content="{Binding Localization[CompetitionDays.SetActive]}"
                                                    Classes="small"
                                                    Command="{Binding $parent[ItemsControl].((pages:CompetitionDaysViewModel)DataContext).SetActiveCommand}"
                                                    CommandParameter="{Binding}"
                                                    IsEnabled="{Binding !IsActive}" />
                                            <Button Classes="danger small"
                                                    ToolTip.Tip="{Binding Localization[CompetitionDays.Delete]}"
                                                    Command="{Binding $parent[ItemsControl].((pages:CompetitionDaysViewModel)DataContext).DeleteDayCommand}"
                                                    CommandParameter="{Binding}"
                                                    IsEnabled="{Binding !IsActive}">
                                                <PathIcon Data="M6,7 h12 M9,7 v-2 h6 v2 M8,7 l1,13 h6 l1,-13"
                                                          Width="15" Height="15" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

    </DockPanel>

</UserControl>

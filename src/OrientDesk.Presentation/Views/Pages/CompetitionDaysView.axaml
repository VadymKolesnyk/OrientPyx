<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="using:OrientDesk.Presentation.ViewModels.Pages"
             xmlns:controls="using:OrientDesk.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="940" d:DesignHeight="560"
             x:Class="OrientDesk.Presentation.Views.Pages.CompetitionDaysView"
             x:DataType="pages:CompetitionDaysViewModel">

    <DockPanel LastChildFill="True">

        <!-- Heading + add action on one line -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="{Binding Title}" Classes="h1"
                           FontSize="{ReflectionBinding TitleFontSize, Source={StaticResource UiScale}}" />
                <TextBlock Text="{Binding Text}" Classes="subtitle" />
            </StackPanel>
            <Button Grid.Column="1" VerticalAlignment="Center"
                    Command="{Binding AddDayCommand}" Classes="accent">
                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                    <PathIcon Data="M11,5 h2 v6 h6 v2 h-6 v6 h-2 v-6 h-6 v-2 h6 z" Width="14" Height="14" Foreground="White" />
                    <TextBlock Text="{Binding Localization[CompetitionDays.Add]}" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Spreadsheet-style grid; the card border supplies the rounded frame.
             SheetDataGrid adds column sort, column reorder (drag) and focus-to-edit. -->
        <Border Classes="card" ClipToBounds="True">
            <controls:SheetDataGrid Name="Sheet"
                                    ItemsSource="{Binding Days}"
                                    AutoGenerateColumns="False">
                <controls:SheetDataGrid.Columns>

                    <!-- Day number + active badge (read-only, sorts by number) -->
                    <DataGridTemplateColumn Width="160" SortMemberPath="Number">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="pages:DayRowViewModel">
                                <StackPanel Orientation="Horizontal" Spacing="8"
                                            VerticalAlignment="Center" Margin="10,0">
                                    <TextBlock Text="{Binding NumberLabel}" Foreground="{DynamicResource TextPrimary}"
                                               FontWeight="Medium" VerticalAlignment="Center" />
                                    <Border Classes="badge" IsVisible="{Binding IsActive}">
                                        <TextBlock Text="{Binding Localization[CompetitionDays.Active]}"
                                                   FontSize="{ReflectionBinding SmallFontSize, Source={StaticResource UiScale}}" />
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Date -->
                    <DataGridTemplateColumn Width="160" MinWidth="140" SortMemberPath="Date">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="pages:DayRowViewModel">
                                <CalendarDatePicker SelectedDate="{Binding Date, Mode=TwoWay,
                                                        Converter={StaticResource DateTimeOffsetToDateTime}}"
                                                    SelectedDateFormat="Custom"
                                                    CustomDateFormatString="dd.MM.yyyy"
                                                    PlaceholderText="{Binding Localization[Common.DatePlaceholder]}"
                                                    HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Venue -->
                    <DataGridTemplateColumn Width="Auto" MinWidth="120" SortMemberPath="Venue">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="pages:DayRowViewModel">
                                <TextBlock Text="{Binding Venue}" VerticalAlignment="Center" Padding="10,0" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate x:DataType="pages:DayRowViewModel">
                                <TextBox Text="{Binding Venue, Mode=TwoWay}" PlaceholderText="—" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Discipline -->
                    <DataGridTemplateColumn Width="180" MinWidth="160" SortMemberPath="SelectedDiscipline.Value">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="pages:DayRowViewModel">
                                <ComboBox HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding DisciplineOptions}"
                                          SelectedItem="{Binding SelectedDiscipline, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="pages:DisciplineTypeOption">
                                            <TextBlock Text="{Binding Label}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Actions: Save / Make current / Delete -->
                    <DataGridTemplateColumn Width="Auto" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="pages:DayRowViewModel">
                                <StackPanel Orientation="Horizontal" Spacing="6"
                                            VerticalAlignment="Center" Margin="10,0">
                                    <Button Content="{Binding Localization[CompetitionDays.Save]}"
                                            Classes="ghost small"
                                            Command="{Binding $parent[DataGrid].((pages:CompetitionDaysViewModel)DataContext).SaveDayCommand}"
                                            CommandParameter="{Binding}"
                                            IsEnabled="{Binding IsDirty}" />
                                    <Button Content="{Binding Localization[CompetitionDays.SetActive]}"
                                            Classes="small"
                                            Command="{Binding $parent[DataGrid].((pages:CompetitionDaysViewModel)DataContext).SetActiveCommand}"
                                            CommandParameter="{Binding}"
                                            IsEnabled="{Binding !IsActive}" />
                                    <Button Classes="danger small"
                                            ToolTip.Tip="{Binding Localization[CompetitionDays.Delete]}"
                                            Command="{Binding $parent[DataGrid].((pages:CompetitionDaysViewModel)DataContext).DeleteDayCommand}"
                                            CommandParameter="{Binding}"
                                            IsEnabled="{Binding !IsActive}">
                                        <PathIcon Data="M6,7 h12 M9,7 v-2 h6 v2 M8,7 l1,13 h6 l1,-13"
                                                  Width="15" Height="15" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </controls:SheetDataGrid.Columns>
            </controls:SheetDataGrid>
        </Border>

    </DockPanel>

</UserControl>

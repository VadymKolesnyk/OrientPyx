<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="using:OrientDesk.Presentation.ViewModels.Pages"
             xmlns:controls="using:OrientDesk.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="940" d:DesignHeight="560"
             x:Class="OrientDesk.Presentation.Views.Pages.ControlPointsView"
             x:DataType="pages:ControlPointsViewModel">

    <DockPanel LastChildFill="True">

        <!-- Heading + add action on one line -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="{Binding Title}" Classes="h1"
                           FontSize="{ReflectionBinding TitleFontSize, Source={StaticResource UiScale}}" />
                <TextBlock Text="{Binding Text}" Classes="subtitle" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                        VerticalAlignment="Center">
                <controls:SearchableComboBox IsVisible="{Binding ShowDaySelector}"
                          MinWidth="120" VerticalAlignment="Center"
                          SearchWatermark="{Binding Localization[Common.Search]}"
                          ItemsSource="{Binding DayOptions}"
                          SelectedItem="{Binding SelectedDay, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="pages:DayOption">
                            <TextBlock Text="{Binding Label}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </controls:SearchableComboBox>
                <Button Name="ImportButton" Classes="ghost" Click="OnImportClick"
                        ToolTip.Tip="{Binding Localization[Import.Hint]}">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <PathIcon Data="M12,3 v10 M8,9 l4,4 l4,-4 M5,15 v3 a1,1 0 0 0 1,1 h12 a1,1 0 0 0 1,-1 v-3"
                                  Width="14" Height="14" />
                        <TextBlock Text="{Binding Localization[Import]}" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding AddPointCommand}" Classes="accent">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <PathIcon Data="M11,5 h2 v6 h6 v2 h-6 v6 h-2 v-6 h-6 v-2 h6 z" Width="14" Height="14" Foreground="White" />
                        <TextBlock Text="{Binding Localization[ControlPoints.Add]}" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Spreadsheet-style table; the card border supplies the rounded frame. Columns are built
             in code-behind (SheetColumnBuilder) and handed to the shared SheetTable via Bands. -->
        <Border Classes="card" ClipToBounds="True">
            <controls:SheetTable Name="Sheet"
                                 ItemsSource="{Binding Points}"
                                 Localization="{Binding Localization}"
                                 SelectedItem="{Binding SelectedPoint, Mode=TwoWay}"
                                 DeleteRequested="OnDeleteRequested" />
        </Border>

    </DockPanel>

</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="using:OrientDesk.Presentation.ViewModels.Pages"
             xmlns:controls="using:OrientDesk.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="640"
             x:Class="OrientDesk.Presentation.Views.Pages.StartProtocolsView"
             x:DataType="pages:StartProtocolsViewModel">

    <DockPanel LastChildFill="True">

        <!-- Heading + day picker + generate button -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="{Binding Title}" Classes="h1"
                           FontSize="{ReflectionBinding TitleFontSize, Source={StaticResource UiScale}}" />
                <TextBlock Text="{Binding Text}" Classes="subtitle" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <controls:SearchableComboBox IsVisible="{Binding ShowDaySelector}"
                          MinWidth="140" VerticalAlignment="Center"
                          SearchWatermark="{Binding Localization[Common.Search]}"
                          ItemsSource="{Binding DayOptions}"
                          SelectedItem="{Binding SelectedDay, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="pages:DayOption">
                            <TextBlock Text="{Binding Label}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </controls:SearchableComboBox>
                <Button Classes="accent" VerticalAlignment="Center"
                        Click="OnGenerateClick"
                        Content="{Binding Localization[Protocols.Generate]}" />
            </StackPanel>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="16" MaxWidth="900">

                <!-- Header text -->
                <Border Classes="card" Padding="22">
                    <StackPanel Spacing="14">
                        <TextBlock Text="{Binding Localization[Protocols.Header.Title]}" Classes="h2"
                                   FontSize="{ReflectionBinding SectionFontSize, Source={StaticResource UiScale}}" />
                        <TextBlock Text="{Binding Localization[Protocols.Header.Hint]}" Classes="subtitle"
                                   TextWrapping="Wrap" />

                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding Localization[Protocols.Header.MainTitle]}" Classes="label" />
                            <TextBox Text="{Binding Title, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding Localization[Protocols.Header.Subtitle]}" Classes="label" />
                            <TextBox Text="{Binding Subtitle, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding Localization[Protocols.Header.CompetitionType]}" Classes="label" />
                            <TextBox Text="{Binding CompetitionType, Mode=TwoWay}" />
                        </StackPanel>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="{Binding Localization[Protocols.Header.Date]}" Classes="label" />
                                <TextBox Text="{Binding DateText, Mode=TwoWay}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="6">
                                <TextBlock Text="{Binding Localization[Protocols.Header.Venue]}" Classes="label" />
                                <TextBox Text="{Binding Venue, Mode=TwoWay}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Layout: orientation -->
                <Border Classes="card" Padding="22">
                    <StackPanel Spacing="14">
                        <TextBlock Text="{Binding Localization[Protocols.Layout.Title]}" Classes="h2"
                                   FontSize="{ReflectionBinding SectionFontSize, Source={StaticResource UiScale}}" />
                        <CheckBox IsChecked="{Binding IsLandscape, Mode=TwoWay}"
                                  Content="{Binding Localization[Protocols.Layout.Landscape]}" />
                    </StackPanel>
                </Border>

                <!-- Live document preview (drag column headers to reorder) -->
                <Border Classes="card" Padding="22">
                    <StackPanel Spacing="14">
                        <TextBlock Text="{Binding Localization[Protocols.Preview.Title]}" Classes="h2"
                                   FontSize="{ReflectionBinding SectionFontSize, Source={StaticResource UiScale}}" />
                        <TextBlock Text="{Binding Localization[Protocols.Preview.Hint]}" Classes="subtitle"
                                   TextWrapping="Wrap" />

                        <Border Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                CornerRadius="4" Padding="20" ClipToBounds="True">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding Preview.Title}" Foreground="Black"
                                           FontWeight="Bold" FontSize="15" TextAlignment="Center"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Preview.Subtitle}" Foreground="Black"
                                           FontSize="12" TextAlignment="Center" TextWrapping="Wrap"
                                           IsVisible="{Binding Preview.Subtitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                <Grid ColumnDefinitions="*,Auto,*" Margin="0,4,0,0">
                                    <TextBlock Grid.Column="0" Text="{Binding Preview.DateText}" Foreground="Black"
                                               FontSize="11" HorizontalAlignment="Left" />
                                    <TextBlock Grid.Column="1" Text="{Binding Preview.CompetitionType}" Foreground="Black"
                                               FontSize="11" HorizontalAlignment="Center" TextWrapping="Wrap" />
                                    <TextBlock Grid.Column="2" Text="{Binding Preview.Venue}" Foreground="Black"
                                               FontSize="11" HorizontalAlignment="Right" />
                                </Grid>

                                <TextBlock Text="{Binding Preview.GroupName}" Foreground="Black"
                                           FontWeight="Bold" FontSize="12" Margin="0,12,0,0"
                                           IsVisible="{Binding Preview.GroupName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                                <TextBlock Text="{Binding Localization[Protocols.Preview.Empty]}" Foreground="#888"
                                           FontStyle="Italic" FontSize="11" Margin="0,10,0,0" TextWrapping="Wrap"
                                           IsVisible="{Binding Preview.IsEmpty}" />

                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                              Margin="0,8,0,0" IsVisible="{Binding !Preview.IsEmpty}">
                                    <Grid x:Name="PreviewTableHost" />
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                        <!-- Column visibility + arrow reorder -->
                        <ItemsControl ItemsSource="{Binding Columns}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="pages:StartProtocolColumnItemViewModel">
                                    <Border Classes="card" Padding="8,4" Margin="0,0,6,6">
                                        <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="4">
                                            <CheckBox Grid.Column="0" VerticalAlignment="Center"
                                                      IsChecked="{Binding Visible, Mode=TwoWay}"
                                                      Content="{Binding Caption}" />
                                            <Button Grid.Column="1" Classes="ghost" Padding="6,3"
                                                    Command="{Binding $parent[ItemsControl].((pages:StartProtocolsViewModel)DataContext).MoveColumnUpCommand}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip.Tip="{Binding $parent[ItemsControl].((pages:StartProtocolsViewModel)DataContext).Localization[Protocols.Columns.Up]}">
                                                <PathIcon Data="M12,8 l5,6 H7 Z" Width="10" Height="10" />
                                            </Button>
                                            <Button Grid.Column="2" Classes="ghost" Padding="6,3"
                                                    Command="{Binding $parent[ItemsControl].((pages:StartProtocolsViewModel)DataContext).MoveColumnDownCommand}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip.Tip="{Binding $parent[ItemsControl].((pages:StartProtocolsViewModel)DataContext).Localization[Protocols.Columns.Down]}">
                                                <PathIcon Data="M7,10 h10 l-5,6 Z" Width="10" Height="10" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Save settings -->
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Content="{Binding Localization[Protocols.SaveSettings]}"
                            Classes="ghost"
                            Command="{Binding SaveSettingsCommand}" />
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                                IsVisible="{Binding SettingsSaved}">
                        <PathIcon Data="M5,12 l4,4 l10,-10" Width="16" Height="16"
                                  Foreground="{DynamicResource SuccessBrush}" />
                        <TextBlock Text="{Binding Localization[Protocols.SettingsSavedHint]}"
                                   Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>

</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="using:OrientDesk.Presentation.ViewModels.Pages"
             xmlns:controls="using:OrientDesk.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="980" d:DesignHeight="720"
             x:Class="OrientDesk.Presentation.Views.Pages.ClassicDrawView"
             x:Name="Root"
             x:DataType="pages:ClassicDrawViewModel">

    <DockPanel LastChildFill="True">

        <!-- Heading + day picker -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="{Binding Localization[Page.ClassicDraw.Title]}" Classes="h1"
                           FontSize="{ReflectionBinding TitleFontSize, Source={StaticResource UiScale}}" />
                <TextBlock Text="{Binding Localization[Page.ClassicDraw.Text]}" Classes="subtitle" />
            </StackPanel>
            <controls:SearchableComboBox Grid.Column="1"
                      IsVisible="{Binding ShowDaySelector}"
                      MinWidth="140" VerticalAlignment="Center"
                      SearchWatermark="{Binding Localization[Common.Search]}"
                      ItemsSource="{Binding DayOptions}"
                      SelectedItem="{Binding SelectedDay, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="pages:DayOption">
                        <TextBlock Text="{Binding Label}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </controls:SearchableComboBox>
        </Grid>

        <!-- Draw parameters (separation) docked above the scroll area. -->
        <Border DockPanel.Dock="Top" Classes="card" Padding="22" Margin="0,0,0,16">
            <StackPanel Spacing="14">
                <TextBlock Text="{Binding Localization[Draw.Section.Params]}" Classes="h2"
                           FontSize="{ReflectionBinding SectionFontSize, Source={StaticResource UiScale}}" />
                <StackPanel Spacing="6" Width="220">
                    <TextBlock Text="{Binding Localization[Draw.SeparationLabel]}" Classes="label" />
                    <ComboBox MinWidth="200"
                              ItemsSource="{Binding SeparationOptions}"
                              SelectedItem="{Binding SelectedSeparation, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="pages:DrawSeparationOption">
                                <TextBlock Text="{Binding Label}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <StackPanel Spacing="16">

                <!-- Groups table -->
                <Border Classes="card" Padding="0" ClipToBounds="True">
                    <DockPanel LastChildFill="True">

                        <!-- Toolbar: select all / none -->
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8"
                                    Margin="16,14,16,12">
                            <TextBlock Text="{Binding Localization[ClassicDraw.Section.Groups]}" Classes="h2"
                                       FontSize="{ReflectionBinding SectionFontSize, Source={StaticResource UiScale}}"
                                       VerticalAlignment="Center" />
                            <Button Classes="ghost small" Content="{Binding Localization[ClassicDraw.SelectAll]}"
                                    Command="{Binding SelectAllCommand}" Margin="16,0,0,0" />
                            <Button Classes="ghost small" Content="{Binding Localization[ClassicDraw.SelectNone]}"
                                    Command="{Binding SelectNoneCommand}" />
                        </StackPanel>

                        <!-- Header row -->
                        <Grid DockPanel.Dock="Top" Background="{DynamicResource SurfaceSubtle}"
                              ColumnDefinitions="60,*,90,70,120,120,130" Height="36">
                            <TextBlock Grid.Column="0" Text="{Binding Localization[ClassicDraw.Col.Selected]}"
                                       FontWeight="Bold" VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding Localization[Draw.Col.Group]}"
                                       FontWeight="Bold" VerticalAlignment="Center" Margin="12,0,0,0" />
                            <TextBlock Grid.Column="2" Text="{Binding Localization[ClassicDraw.Col.Control]}"
                                       FontWeight="Bold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="{Binding Localization[ClassicDraw.Col.Count]}"
                                       FontWeight="Bold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="4" Text="{Binding Localization[ClassicDraw.Col.Start]}"
                                       FontWeight="Bold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="5" Text="{Binding Localization[Draw.Interval]}"
                                       FontWeight="Bold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="6" Text="{Binding Localization[ClassicDraw.Col.FreeMinute]}"
                                       FontWeight="Bold" VerticalAlignment="Center" />
                        </Grid>

                        <ListBox ItemsSource="{Binding Groups}" MaxHeight="520"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="pages:ClassicDrawGroupRowViewModel">
                                    <Grid ColumnDefinitions="60,*,90,70,120,120,130" MinHeight="40">
                                        <CheckBox Grid.Column="0" IsChecked="{Binding Selected, Mode=TwoWay}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="Medium"
                                                   VerticalAlignment="Center" Margin="12,0,0,0" />
                                        <TextBlock Grid.Column="2" Text="{Binding FirstControlLabel}"
                                                   Classes="muted" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Text="{Binding CountLabel}"
                                                   Classes="muted" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="4" Margin="0,4,8,4"
                                                 Text="{Binding Start, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 PlaceholderText="hh:mm:ss" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="5" Margin="0,4,8,4"
                                                 Text="{Binding Interval, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 PlaceholderText="hh:mm:ss" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="6" Text="{Binding FreeMinute}"
                                                   FontFamily="Consolas,monospace" Classes="muted"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <!-- Actions -->
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Classes="accent" Content="{Binding Localization[Draw.Run]}"
                            Command="{Binding RunDrawCommand}" />
                    <TextBlock Text="{Binding StatusMessage}" Classes="subtitle"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Result -->
                <Border Classes="card" Padding="0" IsVisible="{Binding HasResults}" ClipToBounds="True">
                    <DockPanel LastChildFill="True">
                        <Grid DockPanel.Dock="Top" Background="{DynamicResource SurfaceSubtle}"
                              ColumnDefinitions="100,90,*,160,110" Height="36">
                            <TextBlock Grid.Column="0" Text="{Binding Localization[Draw.Col.StartTime]}"
                                       FontWeight="Bold" VerticalAlignment="Center" Margin="12,0,0,0" />
                            <TextBlock Grid.Column="1" Text="{Binding Localization[Draw.Col.Number]}"
                                       FontWeight="Bold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{Binding Localization[Draw.Col.Name]}"
                                       FontWeight="Bold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="{Binding Localization[Draw.Col.Separation]}"
                                       FontWeight="Bold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="4" Text="{Binding Localization[Draw.Col.Group]}"
                                       FontWeight="Bold" VerticalAlignment="Center" />
                        </Grid>
                        <ListBox ItemsSource="{Binding Results}" MaxHeight="420"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="pages:DrawResultRowViewModel">
                                    <Grid ColumnDefinitions="100,90,*,160,110">
                                        <TextBlock Grid.Column="0" Text="{Binding StartTimeLabel}"
                                                   FontFamily="Consolas,monospace" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding Number}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{Binding FullName}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Text="{Binding SeparationValue}"
                                                   Classes="muted" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="4" Text="{Binding GroupName}" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>

</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="using:OrientDesk.Presentation.ViewModels.Pages"
             xmlns:controls="using:OrientDesk.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="940" d:DesignHeight="560"
             x:Class="OrientDesk.Presentation.Views.Pages.DusshView"
             x:DataType="pages:DusshViewModel">

    <DockPanel LastChildFill="True">

        <!-- Heading + actions on one line -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="{Binding Title}" Classes="h1"
                           FontSize="{ReflectionBinding TitleFontSize, Source={StaticResource UiScale}}" />
                <TextBlock Text="{Binding Text}" Classes="subtitle" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                        VerticalAlignment="Center">
                <Button Classes="help" Command="{Binding ShowHelpCommand}"
                        ToolTip.Tip="{Binding Localization[Help.Tooltip]}" />
                <Button Command="{Binding AddDusshCommand}" Classes="accent">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <PathIcon Data="M11,5 h2 v6 h6 v2 h-6 v6 h-2 v-6 h-6 v-2 h6 z" Width="14" Height="14" Foreground="White" />
                        <TextBlock Text="{Binding Localization[Dussh.Add]}" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Spreadsheet-style table; the card border supplies the rounded frame. Columns are built in
             code-behind (SheetColumnBuilder) and handed to the shared SheetTable via Bands. -->
        <Border Classes="card" ClipToBounds="True">
            <controls:SheetTable Name="Sheet"
                                 ItemsSource="{Binding Dusshes}"
                                 Localization="{Binding Localization}"
                                 SelectedItem="{Binding SelectedDussh, Mode=TwoWay}"
                                 DeleteRequested="OnDeleteRequested" />
        </Border>

    </DockPanel>

</UserControl>
